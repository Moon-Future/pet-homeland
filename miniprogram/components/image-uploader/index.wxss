.image-uploader { width: 100%; }
.avatar-section { display: flex; flex-direction: column; align-items: center; padding: 42rpx 24rpx; border-radius: 24rpx; background: rgba(255,255,255,.78); box-shadow: 0 18rpx 38rpx rgba(126,86,194,.12); }
.avatar-wrap { position: relative; width: 164rpx; height: 164rpx; }
.avatar-wrap .avatar-button { position: relative; width: 164rpx; height: 164rpx; border-radius: 50%; overflow: visible; }
.avatar { width: 164rpx; height: 164rpx; border: 8rpx solid rgba(255,255,255,.9); border-radius: 50%; box-sizing: border-box; background: #fff; box-shadow: 0 16rpx 32rpx rgba(126,86,194,.18); }
.camera-button { position: absolute; right: -4rpx; bottom: -4rpx; display: flex; align-items: center; justify-content: center; width: 54rpx; height: 54rpx; border-radius: 50%; background: #8b5cf6; box-shadow: 0 10rpx 20rpx rgba(139,92,246,.26); }
.camera-icon { width: 30rpx; height: 30rpx; }
.avatar-tip { margin-top: 18rpx; color: #786994; font-size: 23rpx; font-weight: 800; }
.crop-overlay { position: fixed; left: 0; right: 0; top: 0; bottom: 0; z-index: 99; display: flex; align-items: center; justify-content: center; padding: 40rpx 28rpx; background: rgba(47,41,64,.48); box-sizing: border-box; }
.crop-panel { width: 100%; padding: 24rpx; border-radius: 24rpx; background: #fff8fb; box-shadow: 0 24rpx 60rpx rgba(47,41,64,.24); box-sizing: border-box; }
.crop-stage { position: relative; width: 100%; height: 620rpx; overflow: hidden; border-radius: 18rpx; background: #201c2a; }
.crop-image { position: absolute; }
.crop-box { position: absolute; border: 4rpx solid #fff; border-radius: 10rpx; box-sizing: border-box; box-shadow: 0 0 0 2000rpx rgba(20,16,30,.5); }
.crop-grid { position: absolute; background: rgba(255,255,255,.48); }
.crop-grid.horizontal { left: 0; right: 0; height: 2rpx; }
.crop-grid.horizontal.top { top: 33.33%; }
.crop-grid.horizontal.bottom { top: 66.66%; }
.crop-grid.vertical { top: 0; bottom: 0; width: 2rpx; }
.crop-grid.vertical.left { left: 33.33%; }
.crop-grid.vertical.right { left: 66.66%; }
.resize-handle { position: absolute; right: -22rpx; bottom: -22rpx; width: 48rpx; height: 48rpx; border: 4rpx solid #fff; border-radius: 50%; background: #8b5cf6; box-shadow: 0 8rpx 18rpx rgba(0,0,0,.22); box-sizing: border-box; }
.resize-handle::after { content: ""; position: absolute; right: 12rpx; bottom: 12rpx; width: 14rpx; height: 14rpx; border-right: 4rpx solid rgba(255,255,255,.9); border-bottom: 4rpx solid rgba(255,255,255,.9); }
.crop-actions { display: grid; grid-template-columns: 1fr 1fr; gap: 18rpx; margin-top: 22rpx; }
.crop-actions .crop-action { width: 100%; height: 78rpx; border-radius: 39rpx; font-size: 27rpx; font-weight: 900; }
.crop-actions .secondary { color: #6d4ed7; background: rgba(139,92,246,.1); }
.crop-actions .primary { color: #fff; background: #8b5cf6; box-shadow: 0 14rpx 28rpx rgba(139,92,246,.24); }
.crop-canvas { position: fixed; left: -9999px; top: -9999px; pointer-events: none; }
