.share-card {
  position: relative;
  overflow: hidden;
  border-radius: 34rpx;
  background: #fffdfb;
  box-shadow:
    0 18rpx 34rpx rgba(153, 103, 76, .12),
    inset 0 0 0 2rpx rgba(255, 244, 233, .86);
}

.illustrated-card {
  background: #fff8f0;
  box-shadow: 0 14rpx 28rpx rgba(165, 120, 88, .14);
}

.illustrated-bg {
  width: 100%;
  display: block;
}

.illustrated-elements {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
}

.illustrated-ele-item {
  position: absolute;
  top: 20rpx;
  left: 24rpx;
  z-index: 100;
}

.illustrated-info-box {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
}

.illustrated-panel {
  position: absolute;
  left: 200rpx;
  top: 140rpx;
  box-sizing: border-box;
}

.illustrated-avatar-shell {
  position: absolute;
  left: 50rpx;
  top: 162rpx;
  width: 120rpx;
  height: 160rpx;
  border-radius: 10rpx;
  background: rgba(255, 255, 255);
  box-sizing: border-box;
  rotate: -5deg;
  padding: 6rpx;
  border: 1px solid rgba(233, 196, 150, .86);
}

.illustrated-avatar {
  width: 100%;
  height: 100%;
  border-radius: 6rpx;
  border: 1px dashed rgba(233, 196, 150, .86);
  box-sizing: border-box;
}

.illustrated-info {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.illustrated-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  color: #916747;
  font-size: 18rpx;
  font-weight: 800;
}

.illustrated-row text:last-child {
  color: #5d3820;
  word-break: break-all;
  white-space: normal;
}

.illustrated-row .highlight {
  color: #df835b;
  font-size: 21rpx;
}

.illustrated-row-desc text:last-child {
  line-height: 1.4;
}

.illustrated-qr-shell {
  position: absolute;
  right: 22rpx;
  bottom: 12rpx;
  box-sizing: border-box;
  border-radius: 50%;
  z-index: 200;
}

.illustrated-qr {
  width: 80rpx;
  height: 80rpx;
  display: block;
  border-radius: 50%;
}
