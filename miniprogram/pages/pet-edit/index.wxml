<view class="page">
  <image-uploader
    id="petCoverUploader"
    value="{{form.coverUrl}}"
    pet-space-id="{{petSpaceId}}"
    image-type="petCover"
    crop-ratio="1:1"
    tip="点击照片拍照或从相册选择"
    bindchange="onPetPhotoChange"
  />

  <view class="panel">
    <view class="field">
      <text class="field-label">宝贝名字</text>
      <input class="input" value="{{form.petName}}" placeholder="输入宠物名字" bindinput="onNameInput" maxlength="24" />
    </view>

    <view class="field">
      <text class="field-label">宠物类型</text>
      <view class="chip-row">
        <view wx:for="{{petTypes}}" wx:key="id" class="chip {{form.petType === item.id ? 'active' : ''}}" data-type="{{item.id}}" bindtap="setPetType">{{item.label}}</view>
      </view>
    </view>

    <view class="field">
      <text class="field-label">性别</text>
      <view class="chip-row">
        <view wx:for="{{genders}}" wx:key="id" class="chip {{form.gender === item.id ? 'active' : ''}}" data-gender="{{item.id}}" bindtap="setGender">{{item.label}}</view>
      </view>
    </view>

    <view class="field">
      <text class="field-label">品种</text>
      <input class="input" value="{{form.breed}}" placeholder="可不填" bindinput="onBreedInput" maxlength="24" />
    </view>

    <view class="field">
      <text class="field-label">宠物状态</text>
      <view class="status-options">
        <view class="status-option {{form.lifeStatus === 'with_me' ? 'active' : ''}}" data-status="with_me" bindtap="setLifeStatus">
          <text>陪伴中</text>
          <text class="option-note">记录每天的陪伴</text>
        </view>
        <view class="status-option {{form.lifeStatus === 'in_stars' ? 'active' : ''}}" data-status="in_stars" bindtap="setLifeStatus">
          <text>已去星星</text>
          <text class="option-note">安放珍贵的想念</text>
        </view>
      </view>
    </view>

    <view class="field">
      <text class="field-label">出生日期</text>
      <picker mode="date" end="{{today}}" value="{{form.birthDate}}" data-field="birthDate" bindchange="onDateChange">
        <view class="date-input">{{form.birthDate || '选择出生日期，可不填'}}</view>
      </picker>
    </view>

    <view class="field">
      <text class="field-label">来到身边日期</text>
      <picker mode="date" end="{{today}}" value="{{form.arrivalDate}}" data-field="arrivalDate" bindchange="onDateChange">
        <view class="date-input">{{form.arrivalDate || '选择来到身边的日期，可不填'}}</view>
      </picker>
    </view>

    <view wx:if="{{form.lifeStatus === 'in_stars'}}" class="field">
      <text class="field-label">离去日期</text>
      <picker mode="date" end="{{today}}" value="{{form.deathDate}}" data-field="deathDate" bindchange="onDateChange">
        <view class="date-input">{{form.deathDate || '选择离去日期'}}</view>
      </picker>
    </view>

    <view class="field">
      <text class="field-label">一句话介绍</text>
      <textarea class="textarea" value="{{form.story}}" placeholder="写下你最想记住的它" bindinput="onStoryInput" maxlength="120" />
    </view>
  </view>

  <view class="panel">
    <view class="field">
      <text class="field-label">谁可以看见小窝</text>
      <view class="visibility-options">
        <view
          wx:for="{{visibilityOptions}}"
          wx:key="id"
          class="visibility-option {{form.visibility === item.id ? 'active' : ''}}"
          data-visibility="{{item.id}}"
          bindtap="setVisibility"
        >
          <text>{{item.label}}</text>
          <text class="option-note">{{item.note}}</text>
        </view>
      </view>
    </view>

    <text class="field-label">小窝主题</text>
    <view class="theme-grid">
      <view wx:for="{{themes}}" wx:key="id" class="theme-card {{selectedTheme === item.id ? 'active' : ''}}" data-id="{{item.id}}" bindtap="selectTheme">
        <image class="theme-image" src="{{item.image}}" mode="aspectFill"></image>
        <view class="theme-name">{{item.name}}</view>
      </view>
    </view>
  </view>

  <button class="save-button" disabled="{{saving || loading}}" bindtap="savePetSpace">
    <text>{{saving ? '保存中...' : '保存小窝'}}</text>
  </button>

  <view wx:if="{{saving}}" class="submit-mask" catchtouchmove="noop">
    <view class="submit-dialog">
      <view class="submit-spinner"></view>
      <text class="submit-title">正在保存</text>
      <text class="submit-desc">请稍候，正在处理照片和资料</text>
    </view>
  </view>
</view>
