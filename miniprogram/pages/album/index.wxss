page { min-height: 100vh; background: #fff4ef; }
.page { min-height: 100vh; padding: 34rpx 26rpx; background: linear-gradient(180deg,#fff3ec,#fff8fb); }
.header { display: flex; align-items: center; justify-content: center; position: relative; }
.title { color: #2f2940; font-size: 34rpx; font-weight: 900; }
.add { position: absolute; right: 0; width: 48rpx; height: 48rpx; display: flex; align-items: center; justify-content: center; border-radius: 50%; color: #fff; background: linear-gradient(135deg,#b46dff,#8b5cf6); font-size: 34rpx; font-weight: 900; }
.filters { margin-top: 28rpx; white-space: nowrap; }
.filter-list { display: flex; gap: 14rpx; }
.filter { padding: 13rpx 28rpx; border-radius: 999rpx; color: #74668f; background: rgba(255,255,255,.8); font-size: 23rpx; font-weight: 800; }
.filter.active { color: #fff; background: linear-gradient(135deg,#b46dff,#8b5cf6); }
.photo-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 12rpx; margin-top: 26rpx; }
.photo { aspect-ratio: 1; overflow: hidden; border-radius: 18rpx; background: #fff; box-shadow: 0 10rpx 20rpx rgba(83,70,166,.12); }
.photo image { width: 100%; height: 100%; }
.state { margin-top: 120rpx; color: #74668f; text-align: center; font-size: 25rpx; font-weight: 800; }
.empty { display: flex; flex-direction: column; align-items: center; margin-top: 120rpx; text-align: center; }
.empty image { width: 168rpx; height: 168rpx; border-radius: 50%; background: #fff; box-shadow: 0 14rpx 30rpx rgba(126,84,230,.12); }
.empty-title { margin-top: 24rpx; color: #2f2940; font-size: 32rpx; font-weight: 900; }
.empty-desc { width: 520rpx; margin-top: 10rpx; color: #74668f; font-size: 24rpx; font-weight: 800; line-height: 1.45; }
