page {
  min-height: 100vh;
  background: #fff8f5;
}

.page {
  min-height: 100vh;
}

.state {
  min-height: 100vh;
  padding: 80rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 18rpx;
  color: #5d526e;
  text-align: center;
  box-sizing: border-box;
}

.state-title {
  color: #2f2940;
  font-size: 34rpx;
  font-weight: 900;
}

.state-desc {
  color: #7d708f;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 1.45;
}

.state button {
  width: 260rpx;
  min-width: 0;
  height: 74rpx;
  margin-top: 16rpx;
  border-radius: 8rpx;
  color: #fff;
  background: #8b5cf6;
  font-size: 27rpx;
  font-weight: 900;
}

button::after {
  border: 0;
}

.identity {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
}

.cover {
  position: fixed;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
}

.shade {
  position: fixed;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(180deg, rgba(34, 26, 42, .12) 0%, rgba(34, 26, 42, .24) 38%, rgba(255, 248, 245, .9) 78%, #fff8f5 100%);
}

.hero {
  position: relative;
  z-index: 1;
  padding: 64rpx 40rpx 220rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  color: #fff;
  text-shadow: 0 6rpx 18rpx rgba(45, 33, 64, .3);
}

.avatar {
  width: 142rpx;
  height: 142rpx;
  border: 8rpx solid rgba(255, 255, 255, .86);
  border-radius: 50%;
  background: #fff;
  box-shadow: 0 18rpx 38rpx rgba(45, 33, 64, .24);
}

.name {
  margin-top: 22rpx;
  font-size: 54rpx;
  font-weight: 900;
  line-height: 1.12;
}

.phase {
  margin-top: 16rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, .24);
  font-size: 24rpx;
  font-weight: 900;
}

.panel {
  position: relative;
  z-index: 2;
  margin: -170rpx 24rpx 40rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.identity-card,
.profile-card {
  padding: 26rpx;
  border: 2rpx solid rgba(255, 255, 255, .72);
  border-radius: 8rpx;
  background: rgba(255, 255, 255, .86);
  box-shadow: 0 16rpx 34rpx rgba(126, 86, 194, .12);
}

.card-label {
  color: #7d708f;
  font-size: 23rpx;
  font-weight: 800;
}

.identity-no {
  display: block;
  margin-top: 10rpx;
  color: #2f2940;
  font-size: 40rpx;
  font-weight: 900;
  letter-spacing: 0;
}

.card-row,
.profile-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 18rpx;
  color: #5e526f;
  font-size: 24rpx;
  font-weight: 800;
}

.card-row text:first-child,
.profile-row text:first-child {
  color: #9a7791;
}

.story {
  display: block;
  margin-top: 22rpx;
  color: #5e526f;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 1.55;
}

.actions {
  display: flex;
  gap: 14rpx;
}

.actions button {
  flex: 1;
  min-width: 0;
  height: 78rpx;
  margin: 0;
  padding: 0 16rpx;
  border-radius: 8rpx;
  font-size: 27rpx;
  font-weight: 900;
}

.actions .primary {
  color: #fff;
  background: #8b5cf6;
}

.actions .plain {
  color: #6f6090;
  background: rgba(255, 255, 255, .86);
}
