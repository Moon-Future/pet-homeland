page {
  min-height: 100vh;
  background: #fff3ea;
}

.page {
  min-height: 100vh;
}

.state {
  min-height: 100vh;
  padding: 80rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 18rpx;
  color: #6d625f;
  text-align: center;
  box-sizing: border-box;
}

.state-title {
  color: #372820;
  font-size: 38rpx;
  font-weight: 900;
}

.state-desc {
  color: #816f69;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.5;
}

.state button,
button::after {
  border: 0;
}

.state button {
  width: 280rpx;
  min-width: 0;
  height: 80rpx;
  margin-top: 16rpx;
  border-radius: 999rpx;
  color: #fff;
  background: linear-gradient(135deg, #df8b56, #c96a43);
  font-size: 28rpx;
  font-weight: 900;
}

.identity {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  padding-bottom: 54rpx;
}

.cover,
.shade {
  position: fixed;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
}

.shade {
  background:
    radial-gradient(circle at 20% 12%, rgba(255, 226, 198, .55), transparent 24%),
    radial-gradient(circle at 78% 18%, rgba(255, 214, 229, .42), transparent 22%),
    linear-gradient(180deg, rgba(83, 45, 25, .16) 0%, rgba(83, 45, 25, .24) 32%, rgba(255, 243, 234, .94) 72%, #fff3ea 100%);
}

.top-copy,
.activation-shell,
.workshop {
  position: relative;
  z-index: 1;
}

.top-copy {
  padding: 72rpx 34rpx 0;
  color: #fffdf7;
  text-shadow: 0 8rpx 20rpx rgba(56, 35, 25, .26);
}

.eyebrow {
  display: inline-flex;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, .22);
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 2rpx;
}

.headline {
  display: block;
  margin-top: 18rpx;
  max-width: 620rpx;
  font-size: 48rpx;
  font-weight: 900;
  line-height: 1.18;
}

.activation-shell {
  padding: 34rpx 28rpx 0;
}

.activation-card {
  position: relative;
  min-height: 420rpx;
  padding: 36rpx 28rpx 28rpx;
  overflow: hidden;
  border: 3rpx solid rgba(255, 255, 255, .46);
  border-radius: 34rpx;
  background: linear-gradient(145deg, rgba(255, 251, 245, .92), rgba(255, 241, 228, .76));
  box-shadow: 0 20rpx 44rpx rgba(117, 73, 49, .18);
  box-sizing: border-box;
}

.activation-halo {
  position: absolute;
  left: 50%;
  top: 92rpx;
  width: 220rpx;
  height: 220rpx;
  margin-left: -110rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 189, 143, .45), rgba(255, 189, 143, 0));
  opacity: 0;
  transform: scale(.7);
  transition: all .45s ease;
}

.activation-avatar {
  position: relative;
  z-index: 1;
  width: 168rpx;
  height: 168rpx;
  margin: 26rpx auto 0;
  display: block;
  border: 8rpx solid rgba(255, 255, 255, .92);
  border-radius: 50%;
  box-shadow: 0 20rpx 30rpx rgba(115, 67, 43, .16);
  opacity: 0;
  transform: translateY(28rpx) scale(.88);
  transition: all .45s ease;
}

.activation-name,
.activation-code,
.activation-stamp,
.activation-tags {
  opacity: 0;
  transition: all .45s ease;
}

.activation-name {
  display: block;
  margin-top: 18rpx;
  text-align: center;
  color: #4f2b17;
  font-size: 40rpx;
  font-weight: 900;
  transform: translateY(12rpx);
}

.activation-code {
  display: block;
  margin-top: 10rpx;
  text-align: center;
  color: #d16a4f;
  font-size: 54rpx;
  font-weight: 900;
  letter-spacing: 2rpx;
  transform: scale(.92);
}

.activation-stamp {
  position: absolute;
  right: 34rpx;
  top: 228rpx;
  width: 132rpx;
  height: 132rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 6rpx solid rgba(214, 104, 80, .62);
  border-radius: 50%;
  color: #d66850;
  background: rgba(255, 255, 255, .84);
  font-size: 28rpx;
  font-weight: 900;
  transform: rotate(-16deg) scale(.7);
}

.activation-tags {
  margin-top: 28rpx;
  display: flex;
  justify-content: center;
  gap: 12rpx;
  flex-wrap: wrap;
  transform: translateY(10rpx);
}

.activation-tags text {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  color: #6f5649;
  background: rgba(255, 255, 255, .82);
  font-size: 22rpx;
  font-weight: 900;
}

.activation-card.stage-1 .activation-halo,
.activation-card.stage-2 .activation-halo,
.activation-card.stage-3 .activation-halo,
.activation-card.stage-4 .activation-halo {
  opacity: 1;
  transform: scale(1);
}

.activation-card.stage-1 .activation-avatar,
.activation-card.stage-2 .activation-avatar,
.activation-card.stage-3 .activation-avatar,
.activation-card.stage-4 .activation-avatar,
.activation-card.stage-2 .activation-name,
.activation-card.stage-3 .activation-name,
.activation-card.stage-4 .activation-name,
.activation-card.stage-2 .activation-code,
.activation-card.stage-3 .activation-code,
.activation-card.stage-4 .activation-code,
.activation-card.stage-3 .activation-stamp,
.activation-card.stage-4 .activation-stamp,
.activation-card.stage-4 .activation-tags {
  opacity: 1;
}

.activation-card.stage-1 .activation-avatar,
.activation-card.stage-2 .activation-avatar,
.activation-card.stage-3 .activation-avatar,
.activation-card.stage-4 .activation-avatar {
  transform: translateY(0) scale(1);
}

.activation-card.stage-2 .activation-name,
.activation-card.stage-3 .activation-name,
.activation-card.stage-4 .activation-name {
  transform: translateY(0);
}

.activation-card.stage-2 .activation-code,
.activation-card.stage-3 .activation-code,
.activation-card.stage-4 .activation-code {
  transform: scale(1);
}

.activation-card.stage-3 .activation-stamp,
.activation-card.stage-4 .activation-stamp {
  transform: rotate(-16deg) scale(1);
}

.activation-card.stage-4 .activation-tags {
  transform: translateY(0);
}

.activation-copy {
  margin-top: 18rpx;
  text-align: center;
  color: #fffdf6;
  font-size: 25rpx;
  font-weight: 800;
  text-shadow: 0 6rpx 18rpx rgba(56, 35, 25, .24);
}

.workshop {
  margin: 30rpx 22rpx 0;
  padding: 24rpx 20rpx 22rpx;
  border: 2rpx solid rgba(255, 255, 255, .56);
  border-radius: 34rpx;
  background:
    linear-gradient(180deg, rgba(255, 251, 247, .92), rgba(255, 245, 238, .86));
  box-shadow: 0 18rpx 44rpx rgba(157, 105, 74, .12);
  backdrop-filter: blur(14rpx);
}

.workshop-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.workshop-copy {
  min-width: 0;
  flex: 1;
}

.workshop-title {
  display: block;
  color: #372820;
  font-size: 34rpx;
  font-weight: 900;
}

.workshop-desc {
  display: block;
  margin-top: 8rpx;
  color: #816f69;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.45;
}

.number-chip {
  padding: 14rpx 18rpx;
  border: 2rpx solid rgba(222, 199, 181, .56);
  border-radius: 22rpx;
  color: #c66a46;
  background: rgba(255, 246, 238, .94);
  font-size: 20rpx;
  font-weight: 900;
  text-align: right;
  box-shadow: inset 0 0 0 2rpx rgba(255, 255, 255, .4);
}

.number-chip text {
  display: block;
}

.template-tabs {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
}

.template-tab {
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  color: #85695c;
  background: linear-gradient(180deg, rgba(255, 255, 255, .96), rgba(255, 245, 237, .9));
  font-size: 23rpx;
  font-weight: 900;
  box-shadow: inset 0 0 0 2rpx rgba(255, 236, 225, .86);
}

.template-tab.active {
  color: #fff;
  background: linear-gradient(135deg, #f3a06b, #ea7f72);
  box-shadow: 0 12rpx 24rpx rgba(234, 127, 114, .22);
}

.preview-shell {
  margin-top: 18rpx;
}

.share-card {
  position: relative;
  overflow: hidden;
  border-radius: 34rpx;
  background: #fffdfb;
  box-shadow:
    0 18rpx 34rpx rgba(153, 103, 76, .12),
    inset 0 0 0 2rpx rgba(255, 244, 233, .86);
}

.resident-card {
  background:
    radial-gradient(circle at 16% 12%, rgba(255, 214, 181, .42), transparent 22%),
    linear-gradient(180deg, #fffefa, #fff6ee 78%);
}

.growth-card {
  background:
    radial-gradient(circle at 82% 14%, rgba(255, 222, 190, .36), transparent 24%),
    linear-gradient(180deg, #fffdf8, #fff2e7);
}

.badge-card {
  background:
    radial-gradient(circle at 20% 14%, rgba(237, 223, 255, .44), transparent 22%),
    linear-gradient(180deg, #fffdfd, #f8f2ff);
}

.card-paws {
  position: absolute;
  right: 24rpx;
  top: 18rpx;
  display: flex;
  gap: 8rpx;
  color: rgba(225, 138, 105, .48);
  font-size: 22rpx;
  font-weight: 900;
}

.soft-paws {
  color: rgba(212, 149, 101, .42);
}

.badge-paws {
  color: rgba(141, 115, 197, .42);
}

.card-orbit {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
  background: radial-gradient(circle, rgba(255, 255, 255, .72), rgba(255, 255, 255, 0));
}

.orbit-left {
  left: -70rpx;
  top: -34rpx;
  width: 210rpx;
  height: 210rpx;
}

.orbit-right {
  right: -36rpx;
  top: 80rpx;
  width: 150rpx;
  height: 150rpx;
}

.orbit-top {
  right: -30rpx;
  top: -56rpx;
  width: 220rpx;
  height: 220rpx;
}

.orbit-bottom {
  left: -44rpx;
  bottom: 120rpx;
  width: 200rpx;
  height: 200rpx;
}

.card-header {
  padding: 24rpx 24rpx 8rpx;
}

.resident-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.card-title {
  display: block;
  color: #4f2b17;
  font-size: 32rpx;
  font-weight: 900;
}

.card-subtitle {
  display: block;
  margin-top: 6rpx;
  color: #b1876e;
  font-size: 18rpx;
  font-weight: 900;
  letter-spacing: 2rpx;
}

.card-seal {
  min-width: 96rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border: 4rpx solid rgba(214, 104, 80, .5);
  border-radius: 50%;
  color: #d66850;
  background: rgba(255, 255, 255, .82);
  font-size: 22rpx;
  font-weight: 900;
  transform: rotate(-12deg);
}

.resident-main {
  padding: 0 22rpx 14rpx;
  display: flex;
  gap: 16rpx;
}

.resident-avatar,
.growth-avatar,
.badge-avatar {
  background: #fff;
}

.resident-avatar {
  width: 186rpx;
  height: 186rpx;
  flex-shrink: 0;
  border: 6rpx solid rgba(224, 198, 173, .92);
  border-radius: 28rpx;
  box-shadow: 0 12rpx 22rpx rgba(117, 73, 49, .12);
}

.resident-facts {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.fact-row {
  padding: 8rpx 0;
  border-bottom: 2rpx solid rgba(224, 208, 194, .38);
}

.fact-label {
  display: block;
  color: #9c7d67;
  font-size: 20rpx;
  font-weight: 800;
}

.fact-value {
  display: block;
  margin-top: 4rpx;
  color: #34241b;
  font-size: 29rpx;
  font-weight: 900;
  line-height: 1.2;
  word-break: break-all;
}

.fact-value.accent {
  color: #d16a4f;
}

.tag-strip {
  padding: 0 22rpx 16rpx;
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}

.tag-chip {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 900;
  box-shadow: inset 0 0 0 2rpx rgba(255, 255, 255, .46);
}

.tag-chip.warm {
  color: #6a4c39;
  background: #f6e4d8;
}

.tag-chip.soft {
  color: #744e38;
  background: #f3e7db;
}

.card-footer {
  min-height: 102rpx;
  padding: 16rpx 20rpx 18rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  color: #fff;
  background: linear-gradient(135deg, #ef9a69, #e57b77);
  box-sizing: border-box;
}

.growth-footer {
  background: linear-gradient(135deg, #f0a774, #e49360);
}

.badge-footer {
  background: linear-gradient(135deg, #8d79d8, #6f91ef);
}

.mini-qr-shell {
  width: 80rpx;
  height: 80rpx;
  padding: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, .2);
  box-sizing: border-box;
}

.mini-qr {
  width: 68rpx;
  height: 68rpx;
  border-radius: 14rpx;
  background: #fff;
}

.card-footer-copy {
  min-width: 0;
  flex: 1;
}

.card-footer-title,
.card-footer-desc {
  display: block;
}

.card-footer-title {
  color: #fffdf8;
  font-size: 24rpx;
  font-weight: 900;
}

.card-footer-desc {
  margin-top: 4rpx;
  color: rgba(255, 255, 255, .76);
  font-size: 19rpx;
  font-weight: 700;
  line-height: 1.4;
}

.growth-card {
  padding: 24rpx 22rpx 0;
}

.growth-top {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.growth-copy {
  flex: 1;
  min-width: 0;
}

.growth-name {
  display: block;
  margin-top: 10rpx;
  color: #372820;
  font-size: 40rpx;
  font-weight: 900;
}

.growth-line {
  display: block;
  margin-top: 6rpx;
  color: #816f69;
  font-size: 22rpx;
  font-weight: 700;
}

.growth-avatar {
  width: 160rpx;
  height: 160rpx;
  flex-shrink: 0;
  border: 6rpx solid rgba(232, 216, 197, .9);
  border-radius: 26rpx;
  box-shadow: 0 14rpx 26rpx rgba(117, 73, 49, .1);
}

.growth-story {
  margin-top: 14rpx;
  padding: 18rpx;
  border: 2rpx solid rgba(244, 228, 215, .8);
  border-radius: 24rpx;
  color: #705a50;
  background: rgba(255, 255, 255, .86);
  font-size: 23rpx;
  font-weight: 700;
  line-height: 1.5;
}

.growth-meta {
  margin-top: 14rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
  margin-bottom: 14rpx;
}

.meta-item {
  min-width: 0;
  padding: 14rpx 12rpx;
  border: 2rpx solid rgba(244, 228, 215, .76);
  border-radius: 20rpx;
  color: #6d5a4d;
  background: rgba(255, 255, 255, .84);
}

.meta-item text:first-child {
  display: block;
  color: #af8f76;
  font-size: 18rpx;
  font-weight: 800;
}

.meta-item text:last-child {
  display: block;
  margin-top: 6rpx;
  color: #372820;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 1.3;
  word-break: break-all;
  white-space: normal;
}

.badge-card {
  padding: 24rpx 22rpx 0;
  text-align: center;
}

.badge-top {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 20rpx;
}

.badge-no {
  color: #8b74c4;
  font-size: 20rpx;
  font-weight: 900;
}

.badge-avatar {
  width: 186rpx;
  height: 186rpx;
  margin: 16rpx auto 0;
  display: block;
  border: 8rpx solid rgba(216, 204, 248, .92);
  border-radius: 50%;
  box-shadow: 0 14rpx 28rpx rgba(81, 62, 118, .12);
}

.badge-name {
  display: block;
  margin-top: 14rpx;
  color: #372820;
  font-size: 38rpx;
  font-weight: 900;
}

.badge-phase {
  display: inline-flex;
  margin-top: 10rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  color: #7e66b5;
  background: rgba(239, 232, 255, .9);
  font-size: 20rpx;
  font-weight: 900;
}

.badge-grid {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
}

.badge-chip {
  min-height: 76rpx;
  padding: 14rpx 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
  color: #4d3978;
  background: rgba(239, 232, 255, .92);
  font-size: 20rpx;
  font-weight: 900;
  box-sizing: border-box;
}

.badge-note {
  margin-top: 12rpx;
  padding: 14rpx 8rpx 16rpx;
  color: #816f69;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.5;
}

.action-grid {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
}

.action-grid.secondary {
  margin-top: 14rpx;
}

.action-grid button {
  width: 100%;
  min-width: 0;
  height: 78rpx;
  margin: 0;
  padding: 0 18rpx;
  line-height: 78rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  font-size: 25rpx;
  font-weight: 900;
  box-sizing: border-box;
}

.action-button {
  width: 100%;
}

.action-grid .primary {
  color: #fff;
  background: linear-gradient(135deg, #f2a56e, #ea7f72);
  box-shadow: 0 14rpx 26rpx rgba(234, 127, 114, .18);
}

.action-grid .plain {
  color: #7a6054;
  background: linear-gradient(180deg, rgba(255, 255, 255, .98), rgba(255, 246, 239, .92));
}

.action-grid .ghost {
  color: #7a6054;
  background: rgba(252, 240, 231, .96);
}

.poster-canvas {
  position: fixed;
  left: -9999rpx;
  top: -9999rpx;
  width: 1080px;
  height: 1440px;
  opacity: 0;
  pointer-events: none;
}

@media (max-width: 360px) {
  .growth-meta,
  .badge-grid,
  .action-grid {
    grid-template-columns: 1fr;
  }

  .template-tabs {
    grid-template-columns: 1fr;
  }

  .resident-main {
    flex-direction: column;
  }

  .resident-avatar,
  .growth-avatar {
    margin: 0 auto;
  }
}
