page {
  min-height: 100vh;
  background: #fff3ea;
}

.page {
  min-height: 100vh;
}

.state {
  min-height: 100vh;
  padding: 80rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 18rpx;
  color: #6d625f;
  text-align: center;
  box-sizing: border-box;
}

.state-title {
  color: #372820;
  font-size: 38rpx;
  font-weight: 900;
}

.state-desc {
  color: #816f69;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.5;
}

.state button,
button::after {
  border: 0;
}

.state button {
  width: 280rpx;
  min-width: 0;
  height: 80rpx;
  margin-top: 16rpx;
  border-radius: 999rpx;
  color: #fff;
  background: linear-gradient(135deg, #df8b56, #c96a43);
  font-size: 28rpx;
  font-weight: 900;
}

.identity {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  padding-bottom: 54rpx;
}

.cover,
.shade {
  position: fixed;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
}

.shade {
  background:
    radial-gradient(circle at 20% 12%, rgba(255, 226, 198, .55), transparent 24%),
    radial-gradient(circle at 78% 18%, rgba(255, 214, 229, .42), transparent 22%),
    linear-gradient(180deg, rgba(83, 45, 25, .16) 0%, rgba(83, 45, 25, .24) 32%, rgba(255, 243, 234, .94) 72%, #fff3ea 100%);
}

.top-copy,
.activation-shell,
.workshop {
  position: relative;
  z-index: 1;
}

.top-copy {
  padding: 20rpx 34rpx 0;
  color: #fffdf7;
  text-shadow: 0 8rpx 20rpx rgba(56, 35, 25, .26);
}

.eyebrow {
  display: inline-flex;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, .22);
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 2rpx;
}

.headline {
  display: block;
  margin-top: 18rpx;
  max-width: 620rpx;
  font-size: 40rpx;
  font-weight: 900;
  line-height: 1.18;
}

.activation-shell {
  padding: 34rpx 28rpx 0;
}

.activation-card {
  position: relative;
  min-height: 420rpx;
  padding: 36rpx 28rpx 28rpx;
  overflow: hidden;
  border: 3rpx solid rgba(255, 255, 255, .46);
  border-radius: 34rpx;
  background: linear-gradient(145deg, rgba(255, 251, 245, .92), rgba(255, 241, 228, .76));
  box-shadow: 0 20rpx 44rpx rgba(117, 73, 49, .18);
  box-sizing: border-box;
}

.activation-avatar {
  position: relative;
  z-index: 1;
  width: 168rpx;
  height: 168rpx;
  margin: 26rpx auto 0;
  display: block;
  border: 8rpx solid rgba(255, 255, 255, .92);
  border-radius: 50%;
  box-shadow: 0 20rpx 30rpx rgba(115, 67, 43, .16);
  opacity: 0;
  transform: translateY(28rpx) scale(.88);
  transition: all .45s ease;
}

.activation-name,
.activation-code,
.activation-stamp,
.activation-tags {
  opacity: 0;
  transition: all .45s ease;
}

.activation-name {
  display: block;
  margin-top: 18rpx;
  text-align: center;
  color: #4f2b17;
  font-size: 40rpx;
  font-weight: 900;
  transform: translateY(12rpx);
}

.activation-code {
  display: block;
  margin-top: 10rpx;
  text-align: center;
  color: #d16a4f;
  font-size: 54rpx;
  font-weight: 900;
  letter-spacing: 2rpx;
  transform: scale(.92);
}

.activation-stamp {
  position: absolute;
  right: 34rpx;
  top: 228rpx;
  width: 132rpx;
  height: 132rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 6rpx solid rgba(214, 104, 80, .62);
  border-radius: 50%;
  color: #d66850;
  background: rgba(255, 255, 255, .84);
  font-size: 28rpx;
  font-weight: 900;
  transform: rotate(-16deg) scale(.7);
}

.activation-tags {
  margin-top: 28rpx;
  display: flex;
  justify-content: center;
  gap: 12rpx;
  flex-wrap: wrap;
  transform: translateY(10rpx);
}

.activation-tags text {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  color: #6f5649;
  background: rgba(255, 255, 255, .82);
  font-size: 22rpx;
  font-weight: 900;
}

.activation-card.stage-1 .activation-avatar,
.activation-card.stage-2 .activation-avatar,
.activation-card.stage-3 .activation-avatar,
.activation-card.stage-4 .activation-avatar,
.activation-card.stage-2 .activation-name,
.activation-card.stage-3 .activation-name,
.activation-card.stage-4 .activation-name,
.activation-card.stage-2 .activation-code,
.activation-card.stage-3 .activation-code,
.activation-card.stage-4 .activation-code,
.activation-card.stage-3 .activation-stamp,
.activation-card.stage-4 .activation-stamp,
.activation-card.stage-4 .activation-tags {
  opacity: 1;
}

.activation-card.stage-1 .activation-avatar,
.activation-card.stage-2 .activation-avatar,
.activation-card.stage-3 .activation-avatar,
.activation-card.stage-4 .activation-avatar {
  transform: translateY(0) scale(1);
}

.activation-card.stage-2 .activation-name,
.activation-card.stage-3 .activation-name,
.activation-card.stage-4 .activation-name {
  transform: translateY(0);
}

.activation-card.stage-2 .activation-code,
.activation-card.stage-3 .activation-code,
.activation-card.stage-4 .activation-code {
  transform: scale(1);
}

.activation-card.stage-3 .activation-stamp,
.activation-card.stage-4 .activation-stamp {
  transform: rotate(-16deg) scale(1);
}

.activation-card.stage-4 .activation-tags {
  transform: translateY(0);
}

.activation-copy {
  margin-top: 18rpx;
  text-align: center;
  color: #fffdf6;
  font-size: 25rpx;
  font-weight: 800;
  text-shadow: 0 6rpx 18rpx rgba(56, 35, 25, .24);
}

.workshop {
  margin: 30rpx 22rpx 0;
  padding: 10rpx 20rpx 22rpx;
  border: 2rpx solid rgba(255, 255, 255, .56);
  border-radius: 34rpx;
  background:
    linear-gradient(180deg, rgba(255, 251, 247, .92), rgba(255, 245, 238, .86));
  box-shadow: 0 18rpx 44rpx rgba(157, 105, 74, .12);
  backdrop-filter: blur(14rpx);
}

.preview-shell {
  margin-top: 8rpx;
}

.action-grid {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
}

.action-grid.secondary {
  margin-top: 14rpx;
}

.action-grid button {
  width: 100%;
  min-width: 0;
  height: 78rpx;
  margin: 0;
  padding: 0 18rpx;
  line-height: 78rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  font-size: 25rpx;
  font-weight: 900;
  box-sizing: border-box;
}

.action-button {
  width: 100%;
}

.action-grid .primary {
  color: #fff;
  background: linear-gradient(135deg, #f2a56e, #ea7f72);
  box-shadow: 0 14rpx 26rpx rgba(234, 127, 114, .18);
}

.action-grid .plain {
  color: #7a6054;
  background: linear-gradient(180deg, rgba(255, 255, 255, .98), rgba(255, 246, 239, .92));
}

.action-grid .ghost {
  color: #7a6054;
  background: rgba(252, 240, 231, .96);
}

.poster-canvas {
  position: fixed;
  left: -9999rpx;
  top: -9999rpx;
  width: 1080px;
  height: 1440px;
  opacity: 0;
  pointer-events: none;
}

@media (max-width: 360px) {
  .action-grid {
    grid-template-columns: 1fr;
  }
}
