page {
  min-height: 100vh;
  background: #fff3ea;
}

.page {
  min-height: 100vh;
}

.state {
  min-height: 100vh;
  padding: 80rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 18rpx;
  color: #6d625f;
  text-align: center;
  box-sizing: border-box;
}

.state-title {
  color: #372820;
  font-size: 38rpx;
  font-weight: 900;
}

.state-desc {
  color: #816f69;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.5;
}

.state button,
button::after {
  border: 0;
}

.state button {
  width: 280rpx;
  min-width: 0;
  height: 80rpx;
  margin-top: 16rpx;
  border-radius: 999rpx;
  color: #fff;
  background: linear-gradient(135deg, #df8b56, #c96a43);
  font-size: 28rpx;
  font-weight: 900;
}

.identity {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  padding-bottom: 54rpx;
}

.cover,
.shade {
  position: fixed;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
}

.shade {
  background:
    radial-gradient(circle at 20% 12%, rgba(255, 226, 198, .34), transparent 24%),
    radial-gradient(circle at 78% 18%, rgba(255, 214, 229, .28), transparent 22%),
    linear-gradient(180deg, rgba(83, 45, 25, .08) 0%, rgba(83, 45, 25, .12) 34%, rgba(255, 243, 234, .52) 78%, rgba(255, 243, 234, .68) 100%);
}

.top-copy,
.activation-shell,
.workshop {
  position: relative;
  z-index: 1;
}

.top-copy {
  padding: 20rpx 34rpx 0;
  color: #fffdf7;
  text-shadow: 0 8rpx 20rpx rgba(56, 35, 25, .26);
}

.eyebrow {
  display: inline-flex;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, .22);
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 2rpx;
}

.headline {
  display: block;
  margin-top: 18rpx;
  font-size: 40rpx;
  font-weight: 900;
  line-height: 1.18;
}

.activation-shell {
  padding: 34rpx 28rpx 0;
}

.activation-card {
  position: relative;
  min-height: 392rpx;
  padding: 42rpx 44rpx 36rpx;
  overflow: hidden;
  border: 3rpx solid rgba(255, 255, 255, .78);
  border-radius: 34rpx;
  background: #fff2dc;
  box-shadow: 0 18rpx 36rpx rgba(168, 103, 66, .22);
  box-sizing: border-box;
}

.activation-card-bg {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
}

.activation-card::after {
  content: "";
  position: absolute;
  left: 44rpx;
  right: 44rpx;
  top: 238rpx;
  height: 2rpx;
  background: linear-gradient(90deg, rgba(166, 112, 72, .18), rgba(166, 112, 72, .04));
}

.activation-brand,
.activation-code,
.activation-stamp,
.activation-tags,
.activation-subline {
  opacity: 0;
  transition: all .45s ease;
}

.activation-brand {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  gap: 18rpx;
  color: #b97845;
  font-size: 32rpx;
  font-weight: 900;
  transform: translateY(14rpx);
}

.activation-badge {
  width: 50rpx;
  height: 58rpx;
  flex-shrink: 0;
}

.activation-chip {
  position: absolute;
  right: 42rpx;
  top: 38rpx;
  width: 98rpx;
  height: 78rpx;
  opacity: .82;
}

.activation-code {
  position: relative;
  z-index: 1;
  display: block;
  margin-top: 76rpx;
  color: #3f281d;
  font-size: 56rpx;
  font-weight: 900;
  letter-spacing: 1rpx;
  line-height: 1.12;
  transform: scale(.92);
}

.activation-divider {
  display: none;
}

.activation-subline {
  position: relative;
  z-index: 1;
  display: block;
  margin-top: 50rpx;
  color: #b18464;
  font-size: 27rpx;
  font-weight: 900;
  transform: translateY(12rpx);
}

.activation-stamp {
  position: absolute;
  right: 5rpx;
  bottom: -5rpx;
  z-index: 2;
  width: 158rpx;
  height: 158rpx;
  transform: rotate(-12deg) scale(.7);
}

.activation-tags {
  position: relative;
  z-index: 1;
  margin-top: 20rpx;
  display: none;
  justify-content: flex-start;
  gap: 12rpx;
  flex-wrap: wrap;
  transform: translateY(10rpx);
}

.activation-tags text {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  color: #6f5649;
  background: rgba(255, 255, 255, .82);
  font-size: 22rpx;
  font-weight: 900;
}

.activation-card.stage-1 .activation-brand,
.activation-card.stage-2 .activation-brand,
.activation-card.stage-3 .activation-brand,
.activation-card.stage-4 .activation-brand,
.activation-card.stage-2 .activation-code,
.activation-card.stage-3 .activation-code,
.activation-card.stage-4 .activation-code,
.activation-card.stage-3 .activation-stamp,
.activation-card.stage-4 .activation-stamp,
.activation-card.stage-4 .activation-subline,
.activation-card.stage-4 .activation-tags {
  opacity: 1;
}

.activation-card.stage-1 .activation-brand,
.activation-card.stage-2 .activation-brand,
.activation-card.stage-3 .activation-brand,
.activation-card.stage-4 .activation-brand,
.activation-card.stage-4 .activation-subline {
  transform: translateY(0);
}

.activation-card.stage-2 .activation-code,
.activation-card.stage-3 .activation-code,
.activation-card.stage-4 .activation-code {
  transform: scale(1);
}

.activation-card.stage-3 .activation-stamp,
.activation-card.stage-4 .activation-stamp {
  transform: rotate(-12deg) scale(1);
}

.activation-card.stage-4 .activation-tags {
  transform: translateY(0);
}

.activation-copy {
  margin-top: 18rpx;
  text-align: center;
  color: #fffdf6;
  font-size: 25rpx;
  font-weight: 800;
  text-shadow: 0 6rpx 18rpx rgba(56, 35, 25, .24);
}

.workshop {
  margin: 30rpx 22rpx 0;
  padding: 10rpx 20rpx 22rpx;
  border: 2rpx solid rgba(255, 255, 255, .56);
  border-radius: 34rpx;
  background:
    linear-gradient(180deg, rgba(255, 251, 247, .92), rgba(255, 245, 238, .86));
  box-shadow: 0 18rpx 44rpx rgba(157, 105, 74, .12);
  backdrop-filter: blur(14rpx);
}

.preview-shell {
  margin-top: 8rpx;
}

.template-tabs {
  display: flex;
  gap: 12rpx;
  margin: 2rpx 0 16rpx;
}

.template-tab {
  flex: 1;
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(190, 142, 93, .16);
  border-radius: 999rpx;
  color: #8a7064;
  background: rgba(255, 255, 255, .66);
  font-size: 23rpx;
  font-weight: 900;
  box-sizing: border-box;
}

.template-tab.active {
  color: #fff;
  border-color: transparent;
  background: linear-gradient(135deg, #8b5cf6, #f45c88);
  box-shadow: 0 10rpx 22rpx rgba(139, 92, 246, .18);
}

.action-grid {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
}

.action-grid.secondary {
  margin-top: 14rpx;
}

.action-grid button {
  width: 100%;
  min-width: 0;
  height: 78rpx;
  margin: 0;
  padding: 0 18rpx;
  line-height: 78rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  font-size: 25rpx;
  font-weight: 900;
  box-sizing: border-box;
}

.action-button {
  width: 100%;
}

.action-grid .primary {
  color: #fff;
  background: linear-gradient(135deg, #f2a56e, #ea7f72);
  box-shadow: 0 14rpx 26rpx rgba(234, 127, 114, .18);
}

.action-grid .plain {
  color: #7a6054;
  background: linear-gradient(180deg, rgba(255, 255, 255, .98), rgba(255, 246, 239, .92));
}

.action-grid .ghost {
  color: #7a6054;
  background: rgba(252, 240, 231, .96);
}

.poster-canvas {
  position: fixed;
  left: -9999rpx;
  top: -9999rpx;
  width: 1080px;
  height: 1440px;
  opacity: 0;
  pointer-events: none;
}

@media (max-width: 360px) {
  .action-grid {
    grid-template-columns: 1fr;
  }
}
