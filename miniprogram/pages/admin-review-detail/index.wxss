page { min-height: 100vh; background: #f6f7fb; }
.page { min-height: 100vh; padding: 24rpx 24rpx 160rpx; box-sizing: border-box; }
.topbar { display: flex; align-items: center; justify-content: space-between; gap: 16rpx; }
.queue-nav { display: flex; align-items: center; gap: 12rpx; }
.nav-button { display: flex; align-items: center; justify-content: center; min-width: 112rpx; height: 56rpx; padding: 0 18rpx; border-radius: 8rpx; color: #4f3f75; background: #fff; box-shadow: 0 8rpx 20rpx rgba(59,47,92,.08); font-size: 23rpx; font-weight: 900; box-sizing: border-box; }
.nav-button.disabled { opacity: .36; }
.queue-count { min-width: 78rpx; color: #837798; font-size: 22rpx; font-weight: 900; text-align: center; }
.state { display: flex; align-items: center; justify-content: center; min-height: 420rpx; color: #7d7190; font-size: 26rpx; font-weight: 900; }
.state.error { color: #b34353; }
.detail { display: flex; flex-direction: column; gap: 18rpx; margin-top: 24rpx; }
.summary { display: grid; grid-template-columns: 150rpx 1fr; gap: 20rpx; padding: 20rpx; border-radius: 8rpx; background: #fff; box-shadow: 0 12rpx 28rpx rgba(59,47,92,.08); }
.cover { width: 150rpx; height: 150rpx; border-radius: 8rpx; background: #eceaf2; }
.summary-copy { min-width: 0; display: flex; flex-direction: column; gap: 10rpx; }
.eyebrow { color: #8b5cf6; font-size: 21rpx; font-weight: 900; }
.title { color: #2f2940; font-size: 34rpx; font-weight: 900; line-height: 1.25; }
.status { align-self: flex-start; padding: 8rpx 14rpx; border-radius: 8rpx; color: #6f6090; background: #f1eef8; font-size: 21rpx; font-weight: 900; }
.status-pending_review { color: #7c5c14; background: #fff0bf; }
.status-approved { color: #21745d; background: #d9f6eb; }
.status-rejected, .status-hidden { color: #b34353; background: #ffe0e6; }
.section { padding: 20rpx; border-radius: 8rpx; background: #fff; box-shadow: 0 12rpx 28rpx rgba(59,47,92,.06); }
.section.warn { background: #fff5f7; }
.section-title { display: block; margin-bottom: 16rpx; color: #2f2940; font-size: 26rpx; font-weight: 900; }
.field { display: grid; grid-template-columns: 170rpx 1fr; gap: 16rpx; padding: 14rpx 0; border-top: 1rpx solid #f0edf5; }
.field:first-of-type { border-top: 0; }
.label { color: #8b8098; font-size: 23rpx; font-weight: 800; }
.value { min-width: 0; color: #3c334b; font-size: 24rpx; font-weight: 800; line-height: 1.45; word-break: break-all; }
.content { display: block; color: #3c334b; font-size: 25rpx; font-weight: 800; line-height: 1.65; white-space: pre-wrap; word-break: break-word; }
.photos { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12rpx; }
.photo { aspect-ratio: 1 / 1; border-radius: 8rpx; overflow: hidden; background: #eceaf2; }
.photo image { width: 100%; height: 100%; display: block; }
.actions { position: fixed; left: 0; right: 0; bottom: 0; display: grid; grid-template-columns: repeat(3, 1fr); gap: 12rpx; padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom)); background: rgba(255,255,255,.96); box-shadow: 0 -10rpx 30rpx rgba(59,47,92,.08); box-sizing: border-box; }
.actions button { width: 100%; height: 70rpx; margin: 0; padding: 0; border-radius: 8rpx; color: #6f6090; background: #f1eef8; font-size: 24rpx; font-weight: 900; line-height: 70rpx; }
.actions button::after { border: 0; }
.actions .primary { color: #fff; background: #8b5cf6; }
.actions .danger { color: #b34353; background: #ffe0e6; }
