page { min-height: 100vh; background: #f7f4fb; }
.page { min-height: 100vh; padding: 32rpx 26rpx 80rpx; box-sizing: border-box; }
.header { display: flex; align-items: center; justify-content: space-between; }
.title { color: #2f2940; font-size: 38rpx; font-weight: 900; }
.refresh { width: 132rpx; height: 60rpx; margin: 0; padding: 0; border-radius: 30rpx; color: #fff; background: #8b5cf6; font-size: 24rpx; font-weight: 900; line-height: 60rpx; }
.refresh::after { border: 0; }
.tabs { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10rpx; margin-top: 28rpx; padding: 8rpx; border-radius: 28rpx; background: rgba(255,255,255,.82); }
.tab { display: flex; align-items: center; justify-content: center; height: 64rpx; border-radius: 22rpx; color: #6f6090; font-size: 24rpx; font-weight: 900; }
.tab.active { color: #fff; background: #8b5cf6; }
.list { display: flex; flex-direction: column; gap: 18rpx; margin-top: 24rpx; }
.review-card { display: grid; grid-template-columns: 120rpx 1fr; gap: 18rpx; padding: 20rpx; border-radius: 8rpx; background: #fff; box-shadow: 0 12rpx 28rpx rgba(68,50,99,.08); }
.review-card.compact { grid-template-columns: 1fr; }
.cover { width: 120rpx; height: 120rpx; border-radius: 8rpx; background: #eee; }
.copy { min-width: 0; display: flex; flex-direction: column; gap: 8rpx; }
.item-title { color: #2f2940; font-size: 28rpx; font-weight: 900; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.desc { color: #5e526f; font-size: 24rpx; line-height: 1.45; font-weight: 700; }
.meta { color: #9a7791; font-size: 21rpx; font-weight: 800; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.actions { grid-column: 1 / -1; display: grid; grid-template-columns: repeat(3, 1fr); gap: 12rpx; }
.actions button { width: 100%; height: 62rpx; margin: 0; padding: 0; border-radius: 8rpx; color: #7a53e8; background: rgba(139,92,246,.1); font-size: 23rpx; font-weight: 900; line-height: 62rpx; }
.actions button::after { border: 0; }
.empty { display: flex; align-items: center; justify-content: center; min-height: 260rpx; color: #8e7ba6; font-size: 26rpx; font-weight: 900; }
