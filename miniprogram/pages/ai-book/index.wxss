page { min-height: 100vh; background: #f7efff; }
.page { min-height: 100vh; padding: 34rpx 26rpx; background: linear-gradient(180deg,#efe6ff,#fff6fb); }
.book { min-height: calc(100vh - 68rpx); display: flex; flex-direction: column; align-items: center; padding: 70rpx 36rpx 40rpx; border-radius: 24rpx; background: linear-gradient(180deg,rgba(255,245,234,.86),rgba(255,255,255,.68)), url("https://qiniu.cdn.cl8023.com/project/star-pet-village/assets/themes/cloud-garden.png") center bottom / cover no-repeat; box-shadow: inset 0 0 0 2rpx rgba(255,255,255,.6); }
.book-title { color: #7b4a70; font-size: 42rpx; font-weight: 900; }
.book-subtitle { margin-top: 12rpx; color: #9a7791; font-size: 24rpx; font-weight: 800; }
.portrait { width: 210rpx; height: 210rpx; margin-top: 86rpx; padding: 10rpx; border-radius: 50%; background: rgba(255,255,255,.8); box-shadow: 0 18rpx 36rpx rgba(126,84,230,.18); }
.portrait image { width: 100%; height: 100%; border-radius: 50%; }
.pet-name { margin-top: 44rpx; color: #7b4a70; font-size: 42rpx; font-weight: 900; }
.date { margin-top: 26rpx; color: #8e7b8a; font-size: 24rpx; font-weight: 700; }
.button { width: 300rpx; height: 78rpx; line-height: 78rpx; margin-top: auto; padding: 0; display: flex; align-items: center; justify-content: center; border-radius: 999rpx; color: #fff; background: linear-gradient(135deg,#b46dff,#8b5cf6); font-size: 28rpx; font-weight: 900; }
.button::after { border: 0; }
