<view class="page">
  <image class="page-bg" src="{{homeBg}}" mode="aspectFill"></image>

  <view class="content">
    <view class="hero-copy">
      <text class="hero-title">星宠乡 🌈</text>
      <text class="hero-subtitle">记录它的一生，也治愈你的余生</text>
    </view>

    <button wx:if="{{isLoggedIn && hasPetSpaces}}" class="create-button" bindtap="onCreateMemorial">
      <image class="create-icon" src="/assets/icons/plus.svg" mode="aspectFit"></image>
      <text class="create-lable">创建宠物小窝</text>
    </button>

    <button wx:elif="{{!isLoggedIn}}" class="create-button" bindtap="goLogin">
      <image class="create-icon" src="/assets/icons/user.svg" mode="aspectFit"></image>
      <text class="create-lable">登录后创建宠物小窝</text>
    </button>

    <view wx:if="{{isLoggedIn && loadingPets && !hasPetSpaces}}" class="recent-card skeleton-card">
      <view class="skeleton-head">
        <view class="skeleton-line title"></view>
        <view class="skeleton-pill"></view>
      </view>
      <view class="skeleton-filter">
        <view class="skeleton-chip"></view>
        <view class="skeleton-chip short"></view>
        <view class="skeleton-chip"></view>
      </view>
      <view class="skeleton-body">
        <view class="skeleton-avatar"></view>
        <view class="skeleton-copy">
          <view class="skeleton-line name"></view>
          <view class="skeleton-line"></view>
          <view class="skeleton-line short"></view>
        </view>
      </view>
    </view>

    <view wx:elif="{{isLoggedIn && hasPetSpaces}}" class="recent-card" bindtap="enterCurrentPet">
      <view class="card-head">
        <text class="card-title">{{featuredPet.recentTitle}}</text>
        <view class="view-all" catchtap="onViewAll">
          <text>全部宠物</text>
          <image class="arrow-icon" src="/assets/icons/chevron-right.svg" mode="aspectFit"></image>
        </view>
      </view>

      <scroll-view class="pet-filter-scroll" scroll-x enable-flex>
        <view class="pet-filter-list">
          <view
            wx:for="{{petSpaces}}"
            wx:key="id"
            class="pet-filter {{item.active ? 'active' : ''}}"
            data-id="{{item.id}}"
            catchtap="onSelectPet"
          >
            <image class="filter-avatar" src="{{item.avatar}}" mode="aspectFill" data-url="{{item.avatar}}"></image>
            <text>{{item.petName}}</text>
          </view>
        </view>
      </scroll-view>

      <view class="card-body">
        <image class="pet-avatar" src="{{featuredPet.avatar}}" mode="aspectFill" data-url="{{featuredPet.avatar}}" catchtap="previewPetAvatar"></image>

        <view class="pet-info">
          <view class="pet-name-row">
            <text class="pet-name">{{featuredPet.petName}}</text>
            <text wx:if="{{featuredPet.genderSymbol}}" class="gender-icon gender-{{featuredPet.genderClass}}">{{featuredPet.genderSymbol}}</text>
            <text class="status-pill {{featuredPet.statusClass}}">{{featuredPet.statusText}}</text>
            <image class="sparkle-icon" src="/assets/icons/sparkle.svg" mode="aspectFit"></image>
          </view>
          <text class="pet-days">{{featuredPet.metricText}}</text>
          <text class="pet-message">{{featuredPet.message}}</text>
        </view>
      </view>
    </view>

    <view wx:elif="{{isLoggedIn && !loadingPets && !hasPetSpaces}}" class="empty-card">
      <image class="empty-image" src="{{defaultPetImage}}" mode="aspectFill"></image>
      <text class="empty-title">还没有宠物小窝</text>
      <text class="empty-desc">创建后，这里会展示你的真实宠物资料。</text>
      <view class="empty-action" bindtap="onCreateMemorial">
        <image src="/assets/icons/plus.svg" mode="aspectFit"></image>
        <text>创建宠物小窝</text>
      </view>
    </view>

    <view wx:else class="guide-card">
      <text class="guide-title">给毛孩子一个温柔小窝</text>
      <text class="guide-desc">登录后保存照片、故事和每一段陪伴时光。</text>
      <view class="theme-strip">
        <view wx:for="{{themePreviews}}" wx:key="id" class="theme-item">
          <image src="{{item.image}}" mode="aspectFill"></image>
          <view class="theme-name">
            <text>{{item.name}}</text>
          </view>
        </view>
      </view>
      <view class="guide-empty" bindtap="goLogin">
        <image src="/assets/icons/paw.svg" mode="aspectFit"></image>
        <text>登录后查看你的小窝</text>
      </view>
    </view>
  </view>
</view>
