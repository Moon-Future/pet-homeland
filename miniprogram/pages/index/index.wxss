page {
  min-height: 100vh;
  background: #7b8ff2;
}

.page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  background: #7b8ff2;
}

.page-bg {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
}

.content {
  position: relative;
  z-index: 1;
  min-height: 100vh;
  padding: 66rpx 26rpx 150rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.hero-copy {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #ffffff;
  text-shadow: 0 5rpx 16rpx rgba(64, 58, 164, 0.32);
}

.hero-title {
  font-size: 48rpx;
  font-weight: 900;
  line-height: 1.15;
  letter-spacing: 0;
}

.hero-subtitle {
  margin-top: 12rpx;
  font-size: 25rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.9);
}

.content .create-button {
  position: absolute;
  left: 118rpx;
  right: 118rpx;
  bottom: 430rpx;
  height: 86rpx;
  line-height: 86rpx;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  border-radius: 999rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #b46dff 0%, #8b5cf6 100%);
  box-shadow: 0 12rpx 26rpx rgba(126, 84, 230, 0.34);
  font-size: 29rpx;
  font-weight: 800;
}

.create-lable {
  font-weight: bold;
}

.content .create-button::after {
  border: 0;
}

.create-icon {
  width: 36rpx;
  height: 36rpx;
}

.recent-card {
  position: absolute;
  left: 34rpx;
  right: 34rpx;
  bottom: 60rpx;
  min-height: 282rpx;
  padding: 24rpx 24rpx 22rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.56);
  border-radius: 30rpx;
  background: linear-gradient(
    135deg,
    rgba(255, 255, 255, 0.84),
    rgba(236, 231, 255, 0.72)
  );
  box-shadow: 0 18rpx 38rpx rgba(83, 70, 166, 0.28);
  backdrop-filter: blur(12px);
}

.guide-card {
  position: absolute;
  left: 34rpx;
  right: 34rpx;
  bottom: 25rpx;
  min-height: 330rpx;
  padding: 26rpx 24rpx 24rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.56);
  border-radius: 30rpx;
  background: linear-gradient(135deg, rgba(255,255,255,.86), rgba(236,231,255,.74));
  box-shadow: 0 18rpx 38rpx rgba(83, 70, 166, 0.28);
  backdrop-filter: blur(12px);
}

.empty-card {
  position: absolute;
  left: 34rpx;
  right: 34rpx;
  bottom: 60rpx;
  min-height: 300rpx;
  padding: 30rpx 24rpx 26rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 3rpx solid rgba(255, 255, 255, 0.56);
  border-radius: 30rpx;
  background: linear-gradient(135deg, rgba(255,255,255,.86), rgba(236,231,255,.74));
  box-shadow: 0 18rpx 38rpx rgba(83, 70, 166, 0.28);
  backdrop-filter: blur(12px);
  opacity: 0.8;
}

.empty-image {
  width: 108rpx;
  height: 108rpx;
  border: 6rpx solid rgba(255,255,255,.92);
  border-radius: 50%;
  background: #fff;
  box-shadow: 0 10rpx 24rpx rgba(126,84,230,.16);
}

.empty-title {
  margin-top: 18rpx;
  color: #2f2940;
  font-size: 30rpx;
  font-weight: 900;
}

.empty-desc {
  margin-top: 8rpx;
  color: #74668f;
  font-size: 24rpx;
  font-weight: 800;
}

.empty-action {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  height: 64rpx;
  margin-top: 20rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  color: #fff;
  background: #8b5cf6;
  font-size: 24rpx;
  font-weight: 900;
  box-shadow: 0 12rpx 24rpx rgba(139,92,246,.24);
}

.empty-action image {
  width: 30rpx;
  height: 30rpx;
}

.guide-title {
  display: block;
  color: #2f2940;
  font-size: 31rpx;
  font-weight: 900;
}

.guide-desc {
  display: block;
  margin-top: 10rpx;
  color: #74668f;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.45;
}

.theme-strip {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 22rpx;
}

.theme-item {
  overflow: hidden;
  border-radius: 18rpx;
  background: rgba(255,255,255,.62);
  color: #5e526f;
  font-size: 20rpx;
  font-weight: 900;
  text-align: center;
}

.theme-item image {
  display: block;
  width: 100%;
  height: 88rpx;
}

.theme-item text {
  display: block;
  padding: 10rpx 4rpx 12rpx;
}

.guide-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  height: 64rpx;
  margin-top: 22rpx;
  border-radius: 999rpx;
  color: #7a53e8;
  background: rgba(139,92,246,.1);
  font-size: 24rpx;
  font-weight: 900;
}

.guide-empty image {
  width: 32rpx;
  height: 32rpx;
}

.card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.pet-filter-scroll {
  width: 100%;
  margin-bottom: 18rpx;
  white-space: nowrap;
}

.pet-filter-list {
  display: flex;
  gap: 12rpx;
}

.pet-filter {
  height: 54rpx;
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 0 18rpx 0 8rpx;
  border: 2rpx solid rgba(147, 104, 235, 0.18);
  border-radius: 999rpx;
  color: #74668f;
  background: rgba(255, 255, 255, 0.58);
  font-size: 22rpx;
  font-weight: 800;
}

.pet-filter.active {
  color: #ffffff;
  border-color: rgba(255, 255, 255, 0.72);
  background: linear-gradient(135deg, #b46dff, #8b5cf6);
  box-shadow: 0 8rpx 18rpx rgba(126, 84, 230, 0.24);
}

.filter-avatar {
  width: 38rpx;
  height: 38rpx;
  border: 2rpx solid #ffffff;
  border-radius: 50%;
}

.card-title {
  color: #2f2940;
  font-size: 30rpx;
  font-weight: 900;
}

.view-all {
  display: flex;
  align-items: center;
  height: 48rpx;
  padding: 0 14rpx 0 18rpx;
  border: 2rpx solid rgba(147, 104, 235, 0.24);
  border-radius: 999rpx;
  color: #7c69c7;
  background: rgba(255, 255, 255, 0.58);
  font-size: 24rpx;
  font-weight: 800;
}

.arrow-icon {
  width: 30rpx;
  height: 30rpx;
  margin-left: 2rpx;
}

.card-body {
  position: relative;
  display: flex;
  align-items: center;
  min-height: 146rpx;
}

.pet-avatar {
  width: 124rpx;
  height: 124rpx;
  flex: 0 0 124rpx;
  border: 6rpx solid #ffffff;
  border-radius: 50%;
  box-shadow: 0 8rpx 22rpx rgba(151, 112, 206, 0.24);
}

.pet-info {
  min-width: 0;
  flex: 1;
  margin-left: 22rpx;
  padding-right: 86rpx;
}

.pet-name-row {
  display: flex;
  align-items: center;
  gap: 5rpx;
}

.pet-name {
  color: #2f2940;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.2;
}

.status-pill {
  height: 32rpx;
  padding: 0 10rpx;
  display: flex;
  align-items: center;
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 18rpx;
  font-weight: 800;
}

.status-with-me {
  background: linear-gradient(135deg, #ff9bbb, #8b5cf6);
}

.status-in-stars {
  background: linear-gradient(135deg, #7f8cff, #5549bd);
}

.sparkle-icon {
  width: 28rpx;
  height: 28rpx;
}

.pet-days {
  display: block;
  margin-top: 8rpx;
  color: #4b405d;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 1.25;
}

.pet-message {
  display: block;
  margin-top: 8rpx;
  color: #7d78a4;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.25;
}

.heart-main {
  position: absolute;
  right: 22rpx;
  top: 20rpx;
  width: 66rpx;
  height: 66rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.88);
  box-shadow: 0 10rpx 22rpx rgba(255, 105, 151, 0.24);
}

.heart-icon {
  width: 45rpx;
  height: 45rpx;
}

.heart-more {
  position: absolute;
  right: 24rpx;
  bottom: 23rpx;
  height: 47rpx;
  min-width: 82rpx;
  padding: 0 14rpx 0 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 2rpx;
  border-radius: 999rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #ff7898, #ff9fae);
  box-shadow: 0 10rpx 18rpx rgba(255, 104, 143, 0.25);
  font-size: 25rpx;
  font-weight: 900;
}

.heart-small {
  width: 34rpx;
  height: 34rpx;
}
