page { min-height: 100vh; background: #fff7f2; }
.page { min-height: 100vh; padding-bottom: 56rpx; background: #fff7f2; }
.hero { position: relative; height: 360rpx; overflow: hidden; }
.hero-bg { width: 100%; height: 100%; }
.hero-shade { position: absolute; left: 0; right: 0; top: 0; bottom: 0; background: linear-gradient(180deg, rgba(35,25,44,.08), rgba(35,25,44,.5)); }
.hero-content { position: absolute; left: 34rpx; right: 34rpx; bottom: 38rpx; display: flex; align-items: center; gap: 20rpx; color: #fff; text-shadow: 0 5rpx 16rpx rgba(45,33,64,.28); }
.pet-avatar { width: 112rpx; height: 112rpx; flex: 0 0 112rpx; border: 6rpx solid rgba(255,255,255,.88); border-radius: 50%; background: #fff; box-shadow: 0 14rpx 30rpx rgba(45,33,64,.22); }
.hero-copy { min-width: 0; display: flex; flex-direction: column; gap: 10rpx; }
.hero-title { font-size: 38rpx; font-weight: 900; line-height: 1.22; }
.hero-subtitle { font-size: 24rpx; font-weight: 800; color: rgba(255,255,255,.9); }
.state { margin-top: 120rpx; color: #7d708f; text-align: center; font-size: 25rpx; font-weight: 800; }
.timeline { position: relative; padding: 34rpx 28rpx 10rpx; }
.timeline-node { display: flex; align-items: stretch; gap: 18rpx; }
.node-rail { position: relative; width: 72rpx; flex: 0 0 72rpx; display: flex; justify-content: center; }
.node-rail::before { content: ""; position: absolute; top: 0; bottom: 0; left: 50%; width: 4rpx; transform: translateX(-50%); background: rgba(244,92,136,.18); }
.timeline-node.first .node-rail::before { top: 34rpx; }
.timeline-node.last .node-rail::before { bottom: calc(100% - 34rpx); }
.node-dot { position: relative; z-index: 1; width: 68rpx; height: 68rpx; margin-top: 4rpx; display: flex; align-items: center; justify-content: center; border: 6rpx solid #fff7f2; border-radius: 50%; color: #fff; background: #f45c88; font-size: 23rpx; font-weight: 900; box-shadow: 0 10rpx 24rpx rgba(244,92,136,.22); box-sizing: border-box; }
.node-card { flex: 1; min-width: 0; margin-bottom: 26rpx; padding: 22rpx 22rpx 24rpx; border: 2rpx solid rgba(245,205,210,.5); border-radius: 8rpx; background: rgba(255,255,255,.88); box-shadow: 0 14rpx 34rpx rgba(152,104,95,.09); box-sizing: border-box; }
.node-meta { display: flex; align-items: center; justify-content: space-between; gap: 14rpx; }
.node-date { color: #9a7791; font-size: 21rpx; font-weight: 900; }
.node-type { flex-shrink: 0; padding: 6rpx 14rpx; border-radius: 999rpx; color: #f45c88; background: rgba(244,92,136,.1); font-size: 20rpx; font-weight: 900; }
.node-title { display: block; margin-top: 12rpx; color: #201b25; font-size: 31rpx; font-weight: 900; line-height: 1.34; }
.node-desc { display: block; margin-top: 8rpx; color: #5e526f; font-size: 24rpx; font-weight: 700; line-height: 1.5; white-space: pre-wrap; }
.node-image { display: block; width: 100%; height: 260rpx; margin-top: 16rpx; border-radius: 8rpx; background: #f1e8e4; }
.type-arrival .node-dot { background: #ff9b65; box-shadow: 0 10rpx 24rpx rgba(255,155,101,.22); }
.type-identity .node-dot { background: #8b5cf6; box-shadow: 0 10rpx 24rpx rgba(139,92,246,.22); }
.type-farewell .node-dot { background: #6574d8; box-shadow: 0 10rpx 24rpx rgba(101,116,216,.22); }
.type-travel .node-dot { background: #31a6a0; box-shadow: 0 10rpx 24rpx rgba(49,166,160,.2); }
.type-health .node-dot { background: #2f9b79; box-shadow: 0 10rpx 24rpx rgba(47,155,121,.2); }
.empty { display: flex; flex-direction: column; align-items: center; margin-top: 120rpx; padding: 0 48rpx; text-align: center; }
.empty image { width: 168rpx; height: 168rpx; border-radius: 50%; background: #fff; box-shadow: 0 14rpx 30rpx rgba(152,104,95,.1); }
.empty-title { margin-top: 24rpx; color: #201b25; font-size: 32rpx; font-weight: 900; }
.empty-desc { margin-top: 10rpx; color: #7d708f; font-size: 24rpx; font-weight: 800; line-height: 1.45; }
.skeleton { min-height: 100vh; background: #fff7f2; }
.skeleton-hero { height: 360rpx; padding: 0 34rpx 38rpx; display: flex; align-items: flex-end; gap: 20rpx; background: linear-gradient(135deg, #f6c9d8, #d9c3ff); box-sizing: border-box; }
.skeleton-avatar { width: 112rpx; height: 112rpx; flex: 0 0 112rpx; border: 6rpx solid rgba(255,255,255,.88); border-radius: 50%; background: rgba(255,255,255,.72); box-sizing: border-box; }
.skeleton-lines { flex: 1; display: flex; flex-direction: column; gap: 16rpx; }
.skeleton-track { padding: 34rpx 28rpx 10rpx; }
.skeleton-node { display: flex; gap: 18rpx; margin-bottom: 26rpx; }
.skeleton-dot { width: 68rpx; height: 68rpx; flex: 0 0 68rpx; border-radius: 50%; background: rgba(255,255,255,.8); }
.skeleton-card { flex: 1; padding: 22rpx; border-radius: 8rpx; background: rgba(255,255,255,.82); display: flex; flex-direction: column; gap: 16rpx; }
.skeleton-line { position: relative; overflow: hidden; border-radius: 999rpx; background: rgba(255,255,255,.72); }
.skeleton-line.title { width: 320rpx; height: 38rpx; }
.skeleton-line.subtitle { width: 220rpx; height: 24rpx; }
.skeleton-line.date { width: 180rpx; height: 22rpx; background: #f0e2df; }
.skeleton-line.card-title { width: 70%; height: 30rpx; background: #f0e2df; }
.skeleton-line.text { width: 100%; height: 24rpx; background: #f0e2df; }
.skeleton-avatar,
.skeleton-dot,
.skeleton-line {
  position: relative;
  overflow: hidden;
}
.skeleton-avatar::after,
.skeleton-dot::after,
.skeleton-line::after {
  content: "";
  position: absolute;
  left: -80%;
  top: 0;
  width: 70%;
  height: 100%;
  background: linear-gradient(90deg, rgba(255,255,255,0), rgba(255,255,255,.7), rgba(255,255,255,0));
  animation: timeline-shimmer 1.25s ease-in-out infinite;
}
@keyframes timeline-shimmer {
  0% { transform: translateX(0); }
  100% { transform: translateX(260%); }
}
