page { min-height: 100vh; background: #f8f0ff; }
.page { min-height: 100vh; padding: 34rpx 26rpx; background: linear-gradient(180deg,#f4ecff,#fff7fb); }
.title { text-align: center; color: #2f2940; font-size: 34rpx; font-weight: 900; }
.tabs { margin-top: 30rpx; white-space: nowrap; }
.tab-list { display: flex; gap: 16rpx; }
.tab { padding: 14rpx 28rpx; border-radius: 999rpx; color: #74668f; background: rgba(255,255,255,.76); font-size: 23rpx; font-weight: 800; }
.tab.active { color: #fff; background: linear-gradient(135deg,#b46dff,#8b5cf6); }
.timeline { margin-top: 28rpx; }
.memory-day { display: grid; grid-template-columns: 28rpx 108rpx 1fr; gap: 16rpx; min-height: 150rpx; }
.axis { position: relative; display: flex; justify-content: center; }
.axis::before { position: absolute; top: 0; bottom: 0; width: 3rpx; background: #c9b9ff; content: ""; }
.dot { z-index: 1; width: 22rpx; height: 22rpx; margin-top: 18rpx; border: 4rpx solid #fff; border-radius: 50%; background: #8b5cf6; }
.year-box { padding-top: 10rpx; }
.year { display: block; color: #2f2940; font-size: 30rpx; font-weight: 900; }
.date { color: #74668f; font-size: 21rpx; font-weight: 700; }
.day-card { margin-bottom: 22rpx; padding: 10rpx; border-radius: 22rpx; background: rgba(255,255,255,.64); box-shadow: 0 10rpx 22rpx rgba(126,84,230,.1); }
.memory-card { display: flex; align-items: center; justify-content: space-between; padding: 14rpx; border-radius: 18rpx; background: rgba(255,255,255,.82); }
.memory-card + .memory-card { margin-top: 10rpx; }
.memory-copy { min-width: 0; }
.memory-row { display: flex; align-items: center; gap: 10rpx; }
.memory-title { display: block; color: #2f2940; font-size: 26rpx; font-weight: 900; }
.type { flex-shrink: 0; padding: 4rpx 10rpx; border-radius: 999rpx; color: #8b5cf6; background: rgba(139,92,246,.1); font-size: 18rpx; font-weight: 900; }
.memory-desc { display: block; margin-top: 8rpx; color: #74668f; font-size: 21rpx; font-weight: 700; }
.memory-img { width: 154rpx; height: 98rpx; border-radius: 18rpx; margin-left: 14rpx; }
.state { margin-top: 120rpx; color: #74668f; text-align: center; font-size: 25rpx; font-weight: 800; }
.empty { display: flex; flex-direction: column; align-items: center; margin-top: 120rpx; text-align: center; }
.empty image { width: 168rpx; height: 168rpx; border-radius: 50%; background: #fff; box-shadow: 0 14rpx 30rpx rgba(126,84,230,.12); }
.empty-title { margin-top: 24rpx; color: #2f2940; font-size: 32rpx; font-weight: 900; }
.empty-desc { margin-top: 10rpx; color: #74668f; font-size: 24rpx; font-weight: 800; }
