<view class="page">
  <view class="moments-cover">
    <image class="cover-img" src="{{pet.cover}}" mode="aspectFill"></image>
    <view class="cover-shade"></view>
    <view class="cover-copy">
      <text class="cover-title">{{pet.name}}的朋友圈</text>
      <text class="cover-subtitle">把每一天都发给未来的自己看</text>
    </view>
    <view class="pet-profile">
      <text class="pet-name">{{pet.name}}</text>
      <image class="pet-avatar" src="{{pet.avatar}}" mode="aspectFill"></image>
    </view>
  </view>

  <scroll-view class="tabs" scroll-x>
    <view class="tab-list">
      <view
        wx:for="{{tabs}}"
        wx:key="id"
        class="tab {{item.id === activeTab ? 'active' : ''}}"
        data-tab="{{item.id}}"
        bindtap="selectTab"
      >{{item.label}}</view>
    </view>
  </scroll-view>

  <view wx:if="{{loading}}" class="state">正在读取动态...</view>

  <view wx:elif="{{groups.length}}" class="moments-list">
    <view wx:for="{{groups}}" wx:key="key" class="day-section">
      <view class="day-label">
        <text class="day-date">{{item.date}}</text>
        <text class="day-count">{{item.countText}}</text>
      </view>

      <view class="day-posts">
        <view wx:for="{{item.items}}" wx:for-item="memory" wx:key="id" class="moment" data-id="{{memory.id}}" bindtap="goMemoryDetail">
          <image class="moment-avatar" src="{{pet.avatar}}" mode="aspectFill"></image>
          <view class="moment-main">
            <view class="moment-head">
              <text class="moment-name">{{pet.name}}</text>
              <text class="type">{{memory.typeLabel}}</text>
            </view>
            <text class="moment-title">{{memory.title}}</text>
            <text class="moment-text">{{memory.desc}}</text>

            <view wx:if="{{memory.mediaUrls.length}}" class="photo-grid photo-count-{{memory.photoCount}}">
              <view
                wx:for="{{memory.mediaUrls}}"
                wx:for-item="photo"
                wx:key="*this"
                class="photo"
                data-id="{{memory.id}}"
                data-url="{{photo}}"
                catchtap="previewMemoryImage"
              >
                <image src="{{photo}}" mode="aspectFill"></image>
              </view>
            </view>

            <view class="moment-foot">
              <text>{{memory.date}}</text>
              <text>查看详情</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view wx:else class="empty">
    <image src="/assets/home/default-pet.png" mode="aspectFill"></image>
    <text class="empty-title">还没有朋友圈动态</text>
    <text class="empty-desc">记录一次日常，{{pet.name}}的朋友圈就会更新。</text>
  </view>
</view>
