<view class="page">
  <view class="title">时间轴</view>
  <scroll-view class="tabs" scroll-x>
    <view class="tab-list">
      <view
        wx:for="{{tabs}}"
        wx:key="id"
        class="tab {{item.id === activeTab ? 'active' : ''}}"
        data-tab="{{item.id}}"
        bindtap="selectTab"
      >{{item.label}}</view>
    </view>
  </scroll-view>

  <view wx:if="{{loading}}" class="state">正在读取回忆...</view>

  <view wx:elif="{{groups.length}}" class="timeline">
    <view wx:for="{{groups}}" wx:key="key" class="memory-day">
      <view class="axis"><view class="dot"></view></view>
      <view class="year-box"><text class="year">{{item.year}}</text><text class="date">{{item.date}}</text></view>
      <view class="day-card">
        <view wx:for="{{item.items}}" wx:for-item="memory" wx:key="id" class="memory-card" data-id="{{memory.id}}" bindtap="goMemoryDetail">
          <view class="memory-copy">
            <view class="memory-row">
              <text class="memory-title">{{memory.title}}</text>
              <text class="type">{{memory.typeLabel}}</text>
            </view>
            <text class="memory-desc">{{memory.desc}}</text>
          </view>
          <image wx:if="{{memory.img}}" class="memory-img" src="{{memory.img}}" mode="aspectFill"></image>
        </view>
      </view>
    </view>
  </view>

  <view wx:else class="empty">
    <image src="/assets/home/default-pet.png" mode="aspectFill"></image>
    <text class="empty-title">还没有回忆</text>
    <text class="empty-desc">记录一次日常，时间轴就会亮起来。</text>
  </view>
</view>
