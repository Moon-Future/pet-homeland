<view class="page">
  <view wx:if="{{initialLoading}}" class="skeleton">
    <view class="skeleton-hero">
      <view class="skeleton-avatar"></view>
      <view class="skeleton-lines">
        <view class="skeleton-line title"></view>
        <view class="skeleton-line subtitle"></view>
      </view>
    </view>
    <view class="skeleton-track">
      <view wx:for="{{skeletonNodes}}" wx:key="*this" class="skeleton-node">
        <view class="skeleton-dot"></view>
        <view class="skeleton-card">
          <view class="skeleton-line date"></view>
          <view class="skeleton-line card-title"></view>
          <view class="skeleton-line text"></view>
        </view>
      </view>
    </view>
  </view>

  <block wx:else>
    <view class="hero">
      <image class="hero-bg" src="{{pet.cover}}" mode="aspectFill"></image>
      <view class="hero-shade"></view>
      <view class="hero-content">
        <image class="pet-avatar" src="{{pet.avatar}}" mode="aspectFill"></image>
        <view class="hero-copy">
          <text class="hero-title">{{pet.name}}的成长时间轴</text>
          <text class="hero-subtitle">{{pet.summary}}</text>
        </view>
      </view>
    </view>

    <view wx:if="{{loading}}" class="state">正在整理时间轴...</view>

    <view wx:elif="{{nodes.length}}" class="timeline">
      <view
        wx:for="{{nodes}}"
        wx:key="id"
        class="timeline-node {{item.isFirst ? 'first' : ''}} {{item.isLast ? 'last' : ''}} type-{{item.type}}"
        data-id="{{item.id}}"
        data-system="{{item.isSystem}}"
        bindtap="goMemoryDetail"
      >
        <view class="node-rail">
          <view class="node-dot">{{item.icon}}</view>
        </view>
        <view class="node-card">
          <view class="node-meta">
            <text class="node-date">{{item.yearText}} · {{item.dateText}}</text>
            <text class="node-type">{{item.typeLabel}}</text>
          </view>
          <text class="node-title">{{item.title}}</text>
          <text class="node-desc">{{item.desc}}</text>
          <image
            wx:if="{{item.image}}"
            class="node-image"
            src="{{item.image}}"
            mode="aspectFill"
            data-url="{{item.image}}"
            catchtap="previewNodeImage"
          ></image>
        </view>
      </view>
    </view>

    <view wx:else class="empty">
      <image src="{{defaultPetImage}}" mode="aspectFill"></image>
      <text class="empty-title">时间轴还没有节点</text>
      <text class="empty-desc">出生、到家和被标记的重要记录，会出现在这里。</text>
    </view>
  </block>
</view>
