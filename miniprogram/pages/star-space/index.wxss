page { min-height: 100vh; background: #081339; }
.page { min-height: 100vh; padding: 42rpx 26rpx 44rpx; background: radial-gradient(circle at 18% 16%, rgba(255,235,174,.24), transparent 17%), radial-gradient(circle at 78% 22%, rgba(139,92,246,.26), transparent 18%), linear-gradient(180deg,#07113a,#102869 56%,#07113a); box-sizing: border-box; }
.header { text-align: center; color: #fff; }
.title { display: block; font-size: 42rpx; font-weight: 900; }
.subtitle { display: block; margin-top: 12rpx; color: rgba(255,255,255,.78); font-size: 24rpx; font-weight: 800; }
.filters { margin-top: 28rpx; white-space: nowrap; }
.filter-list { display: flex; gap: 14rpx; padding-right: 20rpx; }
.filter { padding: 12rpx 24rpx; border-radius: 999rpx; color: rgba(255,255,255,.78); background: rgba(255,255,255,.12); font-size: 23rpx; font-weight: 900; }
.filter.active { color: #172052; background: #fff; }
.sky { position: relative; height: 780rpx; margin-top: 24rpx; overflow: hidden; border-radius: 30rpx; background: rgba(255,255,255,.06); box-shadow: inset 0 0 0 2rpx rgba(255,255,255,.12); }
.sky::before { position: absolute; left: 0; top: 0; width: 100%; height: 100%; background-image: radial-gradient(#fff 0 2rpx, transparent 3rpx); background-size: 88rpx 88rpx; opacity: .35; content: ""; }
.sky-summary { position: absolute; left: 24rpx; right: 24rpx; top: 22rpx; z-index: 2; display: flex; flex-direction: column; gap: 8rpx; color: rgba(255,255,255,.86); font-size: 22rpx; font-weight: 800; }
.star-pet { position: absolute; z-index: 3; display: flex; align-items: center; justify-content: center; border-radius: 50%; transform: translate(-50%, -50%); }
.star-pet image { position: relative; z-index: 2; width: 100%; height: 100%; border: 5rpx solid rgba(255,255,255,.9); border-radius: 50%; background: #fff; box-sizing: border-box; }
.star-ring { position: absolute; left: -10rpx; right: -10rpx; top: -10rpx; bottom: -10rpx; border-radius: 50%; opacity: .84; }
.star-pet.with-me .star-ring { background: radial-gradient(circle, rgba(255,239,174,.56), rgba(255,181,98,.12) 58%, transparent 70%); box-shadow: 0 0 26rpx rgba(255,221,134,.52); }
.star-pet.in-stars .star-ring { background: radial-gradient(circle, rgba(192,204,255,.62), rgba(139,92,246,.15) 58%, transparent 70%); box-shadow: 0 0 30rpx rgba(180,195,255,.62); }
.star-pet.selected image { border-color: #ffe89a; box-shadow: 0 0 0 6rpx rgba(255,232,154,.24); }
.star-pet.selected .star-ring { opacity: 1; transform: scale(1.22); }
.star-skeleton { position: absolute; z-index: 3; border-radius: 50%; background: rgba(255,255,255,.22); box-shadow: 0 0 28rpx rgba(255,255,255,.28); transform: translate(-50%, -50%); animation: pulse 1.2s ease-in-out infinite; }
.size-small { width: 64rpx; height: 64rpx; }
.size-medium { width: 82rpx; height: 82rpx; }
.size-large { width: 104rpx; height: 104rpx; }
.state { position: absolute; left: 0; right: 0; top: 46%; z-index: 4; color: rgba(255,255,255,.84); text-align: center; font-size: 25rpx; font-weight: 900; }
.empty { position: absolute; left: 40rpx; right: 40rpx; top: 42%; z-index: 4; display: flex; flex-direction: column; align-items: center; text-align: center; }
.empty-title { color: #fff; font-size: 30rpx; font-weight: 900; }
.empty-desc { margin-top: 10rpx; color: rgba(255,255,255,.72); font-size: 23rpx; font-weight: 800; line-height: 1.45; }
.empty-action { margin-top: 22rpx; padding: 14rpx 24rpx; border-radius: 999rpx; color: #172052; background: #fff; font-size: 23rpx; font-weight: 900; }
.selected-card { display: flex; align-items: center; gap: 16rpx; min-height: 118rpx; margin-top: 22rpx; padding: 18rpx; border-radius: 22rpx; background: rgba(255,255,255,.14); box-shadow: inset 0 0 0 1rpx rgba(255,255,255,.14), 0 12rpx 26rpx rgba(0,0,0,.12); }
.selected-card image { flex-shrink: 0; width: 82rpx; height: 82rpx; border-radius: 50%; border: 4rpx solid rgba(255,255,255,.82); background: #fff; box-sizing: border-box; }
.select-tip { margin-top: 22rpx; padding: 24rpx; border-radius: 22rpx; color: rgba(255,255,255,.78); background: rgba(255,255,255,.1); text-align: center; font-size: 24rpx; font-weight: 900; }
.pet-copy { min-width: 0; flex: 1; }
.name-row { display: flex; align-items: center; gap: 12rpx; min-width: 0; }
.pet-name { max-width: 250rpx; overflow: hidden; color: #fff; font-size: 27rpx; font-weight: 900; text-overflow: ellipsis; white-space: nowrap; }
.status { flex-shrink: 0; padding: 5rpx 12rpx; border-radius: 999rpx; font-size: 19rpx; font-weight: 900; }
.status.with-me { color: #473500; background: #ffe89a; }
.status.in-stars { color: #fff; background: rgba(139,92,246,.72); }
.meta { display: block; margin-top: 8rpx; overflow: hidden; color: rgba(255,255,255,.72); font-size: 22rpx; font-weight: 800; text-overflow: ellipsis; white-space: nowrap; }
.hint { display: block; margin-top: 8rpx; color: rgba(255,232,154,.9); font-size: 21rpx; font-weight: 900; }
.refresh-button { width: 100%; min-width: 0; height: 84rpx; margin: 26rpx 0 0; padding: 0; display: flex; align-items: center; justify-content: center; border-radius: 999rpx; color: #172052; background: #fff; font-size: 28rpx; font-weight: 900; line-height: 1; box-shadow: 0 16rpx 30rpx rgba(0,0,0,.18); }
.refresh-button::after { border: 0; }

@keyframes pulse {
  0%, 100% { opacity: .38; transform: translate(-50%, -50%) scale(.96); }
  50% { opacity: .9; transform: translate(-50%, -50%) scale(1.06); }
}
