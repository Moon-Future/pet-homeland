page { min-height: 100vh; background: #101858; }
.page { min-height: 100vh; padding: 46rpx 28rpx 38rpx; background: radial-gradient(circle at 18% 22%,rgba(255,231,168,.28),transparent 15%), radial-gradient(circle at 70% 30%,rgba(139,92,246,.35),transparent 20%), linear-gradient(180deg,#07144c,#143c8a 58%,#07144c); }
.title { display: block; text-align: center; color: #fff; font-size: 38rpx; font-weight: 900; }
.subtitle { display: block; text-align: center; margin-top: 12rpx; color: rgba(255,255,255,.78); font-size: 24rpx; font-weight: 800; }
.sky { position: relative; height: 860rpx; margin-top: 22rpx; border-radius: 28rpx; overflow: hidden; }
.sky::before { position: absolute; left: 0; top: 0; width: 100%; height: 100%; background-image: radial-gradient(#fff 0 3rpx,transparent 4rpx); background-size: 92rpx 92rpx; opacity: .45; content: ""; }
.star-dot { position: absolute; width: 70rpx; height: 70rpx; padding: 5rpx; border-radius: 50%; background: rgba(255,255,255,.22); box-shadow: 0 0 24rpx rgba(255,231,168,.52); }
.star-dot image { width: 100%; height: 100%; border-radius: 50%; }
.center-card { position: absolute; left: 50%; top: 45%; transform: translate(-50%,-50%); width: 300rpx; height: 120rpx; display: flex; align-items: center; padding: 18rpx; border-radius: 26rpx; background: rgba(255,255,255,.2); box-shadow: inset 0 0 0 2rpx rgba(255,255,255,.4); backdrop-filter: blur(10px); }
.center-card image { width: 82rpx; height: 82rpx; border-radius: 50%; margin-right: 18rpx; }
.pet-name,.pet-meta { display: block; color: #fff; font-weight: 900; }
.pet-name { font-size: 30rpx; }
.pet-meta { margin-top: 8rpx; font-size: 22rpx; opacity: .78; }
.bottom-actions { display: flex; gap: 16rpx; margin-top: 16rpx; }
.main,.sub { width: 100%; height: 82rpx; line-height: 82rpx; margin: 0; padding: 0; display: flex; align-items: center; justify-content: center; border-radius: 999rpx; font-size: 25rpx; font-weight: 900; }
.main { color: #fff; background: linear-gradient(135deg,#b46dff,#8b5cf6); }
.sub { color: #392a7a; background: rgba(255,255,255,.9); }
.main::after,.sub::after { border: 0; }
