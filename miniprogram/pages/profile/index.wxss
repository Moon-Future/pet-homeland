page { min-height: 100vh; background: #f4e9ff; }
.page { min-height: 100vh; padding: 44rpx 26rpx 140rpx; background: linear-gradient(180deg,#dfcaff,#fff7fb); }
.profile-head { display: flex; align-items: center; position: relative; }
.avatar { width: 132rpx; height: 132rpx; border: 8rpx solid rgba(255,255,255,.8); border-radius: 50%; }
.user-copy { margin-left: 20rpx; }
.name-row { display: flex; align-items: center; gap: 12rpx; }
.name { color: #2f2940; font-size: 36rpx; font-weight: 900; }
.vip { padding: 4rpx 12rpx; border-radius: 999rpx; color: #fff; background: #ffc85c; font-size: 18rpx; font-weight: 900; }
.date { display: block; margin-top: 10rpx; color: #6f6090; font-size: 23rpx; font-weight: 800; }
.settings { position: absolute; right: 8rpx; top: 8rpx; font-size: 36rpx; }
.stats { display: grid; grid-template-columns: repeat(4,1fr); gap: 12rpx; margin-top: 28rpx; padding: 22rpx 0; border-radius: 22rpx; background: rgba(255,255,255,.72); }
.stat { display: flex; flex-direction: column; align-items: center; color: #6f6090; font-size: 22rpx; font-weight: 800; }
.value { color: #2f2940; font-size: 30rpx; font-weight: 900; }
.panel { margin-top: 22rpx; padding: 24rpx; border-radius: 24rpx; background: rgba(255,255,255,.72); }
.panel-title { color: #2f2940; font-size: 27rpx; font-weight: 900; }
.grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 20rpx 12rpx; margin-top: 22rpx; }
.tool { display: flex; flex-direction: column; align-items: center; gap: 10rpx; color: #5e526f; font-size: 21rpx; font-weight: 800; }
.tool image { width: 48rpx; height: 48rpx; }
.tabbar { position: fixed; left: 24rpx; right: 24rpx; bottom: 24rpx; height: 98rpx; display: grid; grid-template-columns: repeat(4,1fr); align-items: center; text-align: center; border-radius: 30rpx; color: #8b83a0; background: rgba(255,255,255,.92); font-size: 22rpx; font-weight: 900; box-shadow: 0 14rpx 30rpx rgba(83,70,166,.18); }
.active { color: #8b5cf6; }
