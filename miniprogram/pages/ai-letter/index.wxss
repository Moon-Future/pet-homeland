page { min-height: 100vh; background: #151d62; }
.page { min-height: 100vh; padding: 46rpx 30rpx 40rpx; background: radial-gradient(circle at 20% 24%,rgba(255,231,168,.28),transparent 18%), radial-gradient(circle at 80% 12%,rgba(255,143,180,.2),transparent 16%), linear-gradient(180deg,#101858,#6d5ed0 70%,#f3c4ea); }
.title { display: block; text-align: center; color: #fff; font-size: 34rpx; font-weight: 900; }
.bottle { position: relative; width: 270rpx; height: 230rpx; margin: 46rpx auto 0; border-radius: 120rpx 120rpx 42rpx 42rpx; background: rgba(255,255,255,.18); box-shadow: inset 0 0 0 6rpx rgba(255,255,255,.3); }
.pet { position: absolute; left: 50%; bottom: 24rpx; width: 132rpx; height: 132rpx; margin-left: -66rpx; border-radius: 50%; }
.tag { position: absolute; left: 50%; top: 40rpx; transform: translateX(-50%) rotate(-10deg); padding: 8rpx 22rpx; border-radius: 12rpx; color: #8a5a2a; background: #ffe1a6; font-size: 24rpx; font-weight: 900; }
.paper { margin-top: -6rpx; padding: 34rpx 34rpx 42rpx; border-radius: 28rpx; background: rgba(255,238,226,.92); box-shadow: 0 16rpx 34rpx rgba(36,25,86,.22); }
.to,.letter,.sign { display: block; color: #5a3c48; font-size: 27rpx; font-weight: 800; line-height: 1.8; white-space: pre-line; }
.letter { margin-top: 14rpx; }
.sign { text-align: right; margin-top: 18rpx; }
.button { width: 320rpx; height: 82rpx; line-height: 82rpx; margin: 56rpx auto 0; padding: 0; display: flex; align-items: center; justify-content: center; border-radius: 999rpx; color: #fff; background: linear-gradient(135deg,#b46dff,#8b5cf6); font-size: 28rpx; font-weight: 900; }
.button::after { border: 0; }
