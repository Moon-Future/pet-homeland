<view class="page">
  <view class="panel">
    <view class="field">
      <text class="field-label">{{entryMode === 'memorial' ? '这段回忆的标题' : '今天的标题'}}</text>
      <input class="input" value="{{form.title}}" placeholder="{{entryMode === 'memorial' ? '可不填，例如：又梦见你了' : '可不填，例如：第一次洗澡'}}" bindinput="onTitleInput" maxlength="32" />
    </view>

    <view class="field">
      <text class="field-label">发生日期</text>
      <picker mode="date" end="{{today}}" value="{{form.memoryDate}}" bindchange="onDateChange">
        <view class="date-input">{{form.memoryDate}}</view>
      </picker>
    </view>

    <view class="field">
      <text class="field-label">记录类型</text>
      <view class="chip-row">
        <view wx:for="{{memoryTypes}}" wx:key="id" class="chip {{form.type === item.id ? 'active' : ''}}" data-type="{{item.id}}" bindtap="selectType">{{item.label}}</view>
      </view>
    </view>

    <view class="timeline-option">
      <view class="timeline-copy">
        <text class="timeline-title">加入成长时间轴</text>
        <text class="timeline-desc">开启后会作为重要节点展示在小窝时间轴里。</text>
      </view>
      <switch checked="{{form.showOnTimeline}}" color="#8b5cf6" bindchange="onTimelineSwitchChange" />
    </view>

    <view class="field">
      <text class="field-label">{{entryMode === 'memorial' ? '想留下什么' : '今天发生了什么'}}</text>
      <textarea class="textarea" value="{{form.content}}" placeholder="{{entryMode === 'memorial' ? '写下想念、梦见的片段，或还想继续说的话' : '写下今天想记住的瞬间'}}" bindinput="onContentInput" maxlength="500" />
    </view>
  </view>

  <view class="panel">
    <view class="image-head">
      <text class="field-label">照片</text>
      <text class="image-count">{{images.length}}/{{maxImages}}</text>
    </view>
    <text class="quota-tip">
      每条最多3张；本账号还可上传 {{quota.loading ? '...' : quota.displayRemaining}}/{{quota.limit}} 张回忆图片，头像和小窝封面不计入。
    </text>

    <view class="image-grid">
      <view wx:for="{{images}}" wx:key="tempFilePath" class="image-item">
        <image src="{{item.tempFilePath}}" mode="aspectFill"></image>
        <view class="remove" data-index="{{index}}" bindtap="removeImage">×</view>
      </view>
      <view wx:if="{{images.length < maxImages}}" class="image-picker">
        <image-uploader
          id="memoryImageUploader"
          value="/assets/icons/camera.svg"
          image-type="memory"
          pet-space-id="{{petSpaceId}}"
          pet-upload-grant="{{petUploadGrant}}"
          crop-ratio="free"
          tip="上传照片"
          bindchange="onMemoryImageChange"
        />
      </view>
    </view>
  </view>

  <button class="save-button" disabled="{{saving || deleting}}" bindtap="saveMemory">
    <text>{{saving ? '保存中...' : (isEditing ? '保存修改' : (entryMode === 'memorial' ? '保存回忆' : '保存记录'))}}</text>
  </button>

  <button wx:if="{{isEditing}}" class="delete-button" disabled="{{saving || deleting}}" bindtap="deleteMemory">
    <text>{{deleting ? '删除中...' : '删除这条日常'}}</text>
  </button>

  <view wx:if="{{saving || deleting}}" class="submit-mask" catchtouchmove="noop">
    <view class="submit-dialog">
      <view class="submit-spinner"></view>
      <text class="submit-title">{{deleting ? '正在删除' : '正在保存'}}</text>
      <text class="submit-desc">请稍候，正在处理照片和资料</text>
    </view>
  </view>
</view>
