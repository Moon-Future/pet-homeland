<view class="page">
  <block wx:if="{{hasPet}}">
    <image class="theme-bg" src="{{pet.cover}}" mode="aspectFill"></image>
    <view class="theme-shade"></view>

    <view class="topbar">
      <view class="topbar-actions">
        <button wx:if="{{canSharePet}}" class="share-button" open-type="share">
          <image class="share" src="/assets/icons/share.svg" mode="aspectFit"></image>
        </button>
        <button wx:if="{{isOwner}}" class="edit-button" bindtap="goEditPet">
          <text class="edit-label">设置</text>
          <image src="/assets/icons/settings.svg" mode="aspectFit"></image>
        </button>
      </view>
    </view>

    <view class="hero">
      <view class="hero-top">
        <image class="pet-photo" src="{{pet.avatar}}" mode="aspectFill" bindtap="previewAvatar"></image>
        <view class="hero-copy">
          <view class="hero-main">
            <text class="name">{{pet.name}}</text>
            <text wx:if="{{pet.genderSymbol}}" class="gender-icon gender-{{pet.genderClass}}">{{pet.genderSymbol}}</text>
            <text class="status-badge">{{pet.status}}</text>
          </view>
          <text class="date">{{pet.dateText}}</text>
          <text class="pill">{{pet.dayText}}</text>
        </view>
      </view>
      <view wx:if="{{pet.identityClaimed}}" class="hero-identity tap-feedback" hover-class="tap-feedback-hover" bindtap="goIdentity">
        <view class="hero-identity-copy">
          <text class="hero-identity-label">数字身份编号</text>
          <text class="hero-identity-no">{{pet.identityNo}}</text>
        </view>
        <image class="hero-identity-arrow" src="/assets/icons/chevron-right.svg" mode="aspectFit"></image>
      </view>
      <view wx:elif="{{isOwner}}" class="hero-identity hero-identity-claim">
        <view class="hero-identity-copy">
          <text class="hero-identity-label">爱宠身份档案</text>
          <text class="hero-identity-desc">每只爱宠都可领取唯一身份编号，领取后会永久展示在档案中。</text>
        </view>
        <button class="hero-identity-button" loading="{{identityClaiming}}" bindtap="claimIdentity">点击领取爱宠身份证</button>
      </view>
    </view>

    <view class="sheet">
      <view wx:if="{{quickActions.length}}" class="section-card interaction-card first-card {{interactionSyncing ? 'syncing' : ''}}">
        <text wx:if="{{showVisitorOverview}}" class="overview-visitor">{{visitorOverviewText}}</text>
        <view class="actions">
          <view wx:for="{{quickActions}}" wx:key="type" class="action {{item.syncing ? 'active-sync' : ''}} tap-feedback" hover-class="tap-feedback-hover" data-type="{{item.type}}" bindtap="interact">
            <view class="action-icon"><image src="{{item.icon}}" mode="aspectFit"></image></view>
            <view class="action-copy">
              <text class="action-label">{{item.label}}</text>
              <text wx:if="{{item.showCount}}" class="action-count">{{item.totalCountText}}</text>
            </view>
          </view>
        </view>
      </view>

      <view class="story-card">
        <view class="story-head">
          <view class="section-title-row">
            <view class="section-icon record-icon">记</view>
            <text>{{isOwner ? '今日记录' : storySectionTitle}}</text>
          </view>
          <view class="story-actions">
            <text wx:if="{{primaryAction}}" class="record-button tap-feedback" hover-class="tap-feedback-hover" bindtap="triggerPrimaryAction">＋ 记录</text>
            <text class="edit" bindtap="goMoments">更多 ›</text>
          </view>
        </view>
        <view wx:if="{{recentMemories.length}}" class="recent-list">
          <view wx:for="{{recentMemories}}" wx:key="id" class="recent-item tap-feedback" hover-class="tap-feedback-hover" data-id="{{item.id}}" bindtap="goMemoryDetail">
            <view class="recent-copy">
              <text class="recent-title">{{item.title}}</text>
              <text class="recent-desc">{{item.content}}</text>
              <text class="recent-date">{{item.date}}</text>
            </view>
            <image wx:if="{{item.img}}" class="recent-img" src="{{item.img}}" mode="aspectFill"></image>
          </view>
        </view>
        <view wx:else class="story-empty">
          <text class="story">{{pet.story}}</text>
          <view wx:if="{{primaryAction}}" class="story-empty-action tap-feedback" hover-class="tap-feedback-hover" bindtap="triggerPrimaryAction">{{primaryAction.buttonText}}</view>
        </view>
      </view>

      <view wx:if="{{timelineNodes.length}}" class="timeline-card tap-feedback" hover-class="tap-feedback-hover" bindtap="goPetTimeline">
        <view class="section-title-row">
          <view class="section-icon timeline-title-icon">时</view>
          <text>成长时间轴</text>
          <image class="timeline-arrow" src="/assets/icons/chevron-right.svg" mode="aspectFit"></image>
        </view>
        <scroll-view class="timeline-scroll" scroll-x enable-flex>
          <view class="timeline-track">
            <view wx:for="{{timelineNodes}}" wx:key="id" class="timeline-node {{item.active ? 'active' : ''}}">
              <view class="timeline-dot">{{item.icon}}</view>
              <text class="timeline-date">{{item.date}}</text>
              <text class="timeline-label">{{item.label}}</text>
            </view>
          </view>
        </scroll-view>
      </view>

      <view class="section-card entry-section">
        <view class="entry-grid">
          <view class="entry album-entry tap-feedback" hover-class="tap-feedback-hover" bindtap="goAlbum">
            <view class="entry-head">
              <image src="/assets/icons/album.svg"></image>
              <text class="entry-label">回忆相册</text>
              <text class="entry-count">{{entryStats.mediaText}} ›</text>
            </view>
            <view class="album-preview">
              <image wx:for="{{albumPreviewImages}}" wx:key="*this" src="{{item}}" mode="aspectFill"></image>
            </view>
          </view>
          <view class="entry friends-entry tap-feedback" hover-class="tap-feedback-hover" bindtap="goMoments">
            <view class="entry-head">
              <image src="/assets/icons/user.svg"></image>
              <text class="entry-label">朋友圈</text>
              <text class="entry-count">{{entryStats.visitorText}} ›</text>
            </view>
            <view class="friends-empty">
              <text class="friends-illus">♡</text>
              <text>{{entryStats.friendHint}}</text>
            </view>
          </view>
        </view>
      </view>

      <view wx:if="{{(viewingPetSpaceId && !isOwner) || reviewNotice}}" class="support-panel {{reviewNotice ? 'review-panel' : ''}} status-{{reviewNotice.type}}">
        <view wx:if="{{viewingPetSpaceId && !isOwner}}" class="support-copy">
          <text class="support-title">正在访问 {{pet.name}} 的小窝</text>
          <text class="support-desc">可以查看公开回忆、留下轻互动，也可以回到自己的小窝。</text>
        </view>
        <view wx:elif="{{reviewNotice}}" class="support-copy status-{{reviewNotice.type}}">
          <view class="support-title-row">
            <view class="support-status-dot"></view>
            <text class="support-title">公开展示状态</text>
          </view>
          <text class="support-desc">{{reviewNotice.text}}</text>
        </view>

        <view class="support-actions">
          <view wx:if="{{viewingPetSpaceId && !isOwner}}" class="support-button primary tap-feedback" hover-class="tap-feedback-hover" bindtap="goMyPetSpace">回我的小窝</view>
          <view wx:if="{{rawPet.visibility === 'discover' && !isOwner}}" class="support-button plain tap-feedback" hover-class="tap-feedback-hover" bindtap="reportPet">举报</view>
          <view wx:if="{{rawPet.visibility === 'discover' && isOwner}}" class="support-button plain wide tap-feedback" hover-class="tap-feedback-hover" bindtap="unpublishPet">隐藏公开展示</view>
        </view>
      </view>
    </view>
  </block>

  <view wx:elif="{{loadingPet && !hasPet}}" class="pet-skeleton">
    <view class="skeleton-bg"></view>
    <view class="skeleton-hero">
      <view class="skeleton-photo"></view>
      <view class="skeleton-line name"></view>
      <view class="skeleton-line date"></view>
      <view class="skeleton-pill"></view>
    </view>
    <view class="skeleton-sheet">
      <view class="skeleton-actions">
        <view wx:for="{{skeletonActions}}" wx:key="*this" class="skeleton-action">
          <view class="skeleton-icon"></view>
          <view class="skeleton-line short"></view>
        </view>
      </view>
      <view class="skeleton-stats">
        <view wx:for="{{skeletonStats}}" wx:key="*this" class="skeleton-stat"></view>
      </view>
      <view class="skeleton-card">
        <view class="skeleton-line card-title"></view>
        <view class="skeleton-line"></view>
        <view class="skeleton-line medium"></view>
      </view>
    </view>
  </view>

  <view wx:elif="{{isLoggedIn && !loadingPet && !hasPet}}" class="login-empty">
    <image class="empty-pet" src="{{defaultPetImage}}" mode="aspectFill"></image>
    <text class="empty-title">还没有宠物小窝</text>
    <text class="empty-desc">创建后，这里会展示真实宠物资料。</text>
    <button class="login-button" bindtap="goCreate">创建宠物小窝</button>
  </view>

  <view wx:else class="login-empty">
    <image class="empty-pet" src="{{defaultPetImage}}" mode="aspectFill"></image>
    <text class="empty-title">登录后查看宠物小窝</text>
    <text class="empty-desc">保存照片、故事和陪伴时光。</text>
    <button class="login-button" bindtap="goLogin">去登录</button>
  </view>
</view>
