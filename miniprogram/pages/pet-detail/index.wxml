<view class="page">
  <block wx:if="{{isLoggedIn && hasPet}}">
    <image class="theme-bg" src="{{pet.cover}}" mode="aspectFill"></image>
    <view class="theme-shade"></view>

    <view class="topbar">
      <button wx:if="{{canSharePet}}" class="share-button" open-type="share">
        <image class="share" src="/assets/icons/share.svg" mode="aspectFit"></image>
      </button>
      <button wx:if="{{isOwner}}" class="edit-button" bindtap="goEditPet">
        <image src="/assets/icons/settings.svg" mode="aspectFit"></image>
      </button>
    </view>

    <view class="hero">
      <image class="pet-photo" src="{{pet.avatar}}" mode="aspectFill"></image>
      <text class="name">{{pet.name}} ✨</text>
      <text class="date">{{pet.dateText}}</text>
      <text class="pill">{{pet.dayText}}</text>
    </view>

    <view class="sheet">
      <view wx:if="{{viewingPetSpaceId && !isOwner}}" class="visitor-tip">
        <text>正在访问 {{pet.name}} 的小窝，可以查看回忆并留下轻互动。</text>
        <text class="visitor-back" bindtap="goMyPetSpace">回到我的小窝</text>
      </view>

      <view wx:if="{{rawPet.visibility === 'discover'}}" class="governance-bar">
        <button wx:if="{{isOwner}}" class="governance-action" bindtap="unpublishPet">下架公开展示</button>
        <button wx:elif="{{!isOwner}}" class="governance-action" bindtap="reportPet">举报</button>
      </view>

      <view class="actions">
        <view wx:for="{{actions}}" wx:key="type" class="action" data-type="{{item.type}}" bindtap="interact">
          <view class="action-icon"><image src="{{item.icon}}" mode="aspectFit"></image></view>
          <text>{{item.label}}</text>
          <text wx:if="{{item.showCount}}" class="action-count">今日 {{item.todayCount}}/{{item.limit}}</text>
        </view>
      </view>

      <view class="stats">
        <view wx:for="{{stats}}" wx:key="label" class="stat">
          <text class="stat-value">{{item.value}}</text>
          <text class="stat-label">{{item.label}}</text>
        </view>
      </view>

      <view wx:if="{{isOwner}}" class="visitor-summary">
        <text>今天有 {{visitorSummary.visitorCountToday}} 位朋友来过</text>
        <text>{{visitorSummary.visitorInteractionCountToday}} 次轻互动被留下</text>
      </view>

      <view class="story-card">
        <view class="story-head">
          <text>{{pet.name}}的小日常</text>
          <text class="edit" bindtap="goTimeline">更多 ›</text>
        </view>
        <view wx:if="{{recentMemories.length}}" class="recent-list">
          <view wx:for="{{recentMemories}}" wx:key="id" class="recent-item" data-id="{{item.id}}" bindtap="goMemoryDetail">
            <view class="recent-copy">
              <text class="recent-title">{{item.title}}</text>
              <text class="recent-desc">{{item.content}}</text>
              <text class="recent-date">{{item.date}}</text>
            </view>
            <image wx:if="{{item.img}}" class="recent-img" src="{{item.img}}" mode="aspectFill"></image>
          </view>
        </view>
        <text wx:else class="story">{{pet.story}}</text>
      </view>

      <view class="entry-grid">
        <view class="entry" bindtap="goTimeline"><image src="/assets/icons/timeline.svg"></image><text>时间轴</text></view>
        <view class="entry" bindtap="goAlbum"><image src="/assets/icons/album.svg"></image><text>回忆相册</text></view>
        <view class="entry" bindtap="goStarSpace"><image src="/assets/icons/star.svg"></image><text>星空</text></view>
      </view>
    </view>
  </block>

  <view wx:elif="{{isLoggedIn && !hasPet}}" class="login-empty">
    <image class="empty-pet" src="/assets/home/default-pet.png" mode="aspectFill"></image>
    <text class="empty-title">还没有宠物小窝</text>
    <text class="empty-desc">创建后，这里会展示真实宠物资料。</text>
    <button class="login-button" bindtap="goCreate">创建宠物小窝</button>
  </view>

  <view wx:else class="login-empty">
    <image class="empty-pet" src="/assets/home/default-pet.png" mode="aspectFill"></image>
    <text class="empty-title">登录后查看宠物小窝</text>
    <text class="empty-desc">保存照片、故事和陪伴时光。</text>
    <button class="login-button" bindtap="goLogin">去登录</button>
  </view>
</view>
