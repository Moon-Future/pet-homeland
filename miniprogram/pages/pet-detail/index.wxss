.skeleton-icon,
.skeleton-thumb,
.skeleton-identity,
.skeleton-friend-mark {
  position: relative;
  overflow: hidden;
  background: rgba(255,255,255,.72);
}
.skeleton-photo::after,
.skeleton-line::after,
.skeleton-pill::after,
.skeleton-round::after,
.skeleton-icon::after,
.skeleton-thumb::after,
.skeleton-identity::after,
.skeleton-friend-mark::after {
  content: "";
  position: absolute;
  left: -80%;
  top: 0;
  width: 70%;
  height: 100%;
  background: linear-gradient(90deg, rgba(255,255,255,0), rgba(255,255,255,.58), rgba(255,255,255,0));
  animation: pet-skeleton-shimmer 1.35s ease-in-out infinite;
}
.skeleton-photo { width: 136rpx; height: 136rpx; flex: 0 0 136rpx; border: 8rpx solid rgba(255,255,255,.82); border-radius: 50%; box-shadow: 0 18rpx 38rpx rgba(45,33,64,.16); box-sizing: border-box; }
.skeleton-line { width: 72%; height: 24rpx; border-radius: 999rpx; }
.skeleton-line.name { width: 240rpx; height: 56rpx; }
.skeleton-line.date { width: 220rpx; margin-top: 18rpx; }
.skeleton-line.short { width: 92rpx; }
.skeleton-line.count { width: 62rpx; height: 34rpx; }
.skeleton-line.medium { width: 52%; }
.skeleton-line.card-title { width: 210rpx; height: 28rpx; }
.skeleton-line.short-title { width: 150rpx; }
.skeleton-line.tiny { width: 76rpx; height: 20rpx; }
.skeleton-pill { width: 280rpx; height: 52rpx; margin-top: 18rpx; border-radius: 999rpx; }
.skeleton-pill.small { width: 82rpx; height: 52rpx; margin-top: 0; background: rgba(255,255,255,.28); }
.skeleton-round { width: 44rpx; height: 44rpx; border-radius: 50%; }
.skeleton-round.small { width: 46rpx; height: 46rpx; background: rgba(255,255,255,.22); }
.skeleton-round.badge { width: 44rpx; height: 44rpx; flex: 0 0 44rpx; }
.skeleton-round.node-dot { width: 48rpx; height: 48rpx; background: rgba(255,232,239,.82); }
.skeleton-icon { width: 82rpx; height: 82rpx; border-radius: 50%; }
.skeleton-thumb { aspect-ratio: 1; border-radius: 14rpx; }

@media (max-width: 360px) {
  .stats-four,
  .stats-three,
  .stats-mixed { grid-template-columns: repeat(2,1fr); }
  .skeleton-entry-grid { grid-template-columns: 1fr; }
}

@keyframes pet-skeleton-shimmer {
  0% { transform: translateX(0); }
  100% { transform: translateX(260%); }
}
