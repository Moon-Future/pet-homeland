.action.is-syncing .action-icon { background: #ffe2eb; box-shadow: 0 10rpx 22rpx rgba(244,92,136,.16); }
.action.is-pulsing .action-icon { animation: actionTap 360ms cubic-bezier(.2,.8,.2,1) both; }
.action.is-pulsing .action-count { animation: countLift 360ms cubic-bezier(.2,.8,.2,1) both; }
@keyframes actionTap {
  0% { transform: translateY(0) scale(1); box-shadow: 0 8rpx 20rpx rgba(244,92,136,.12); }
  45% { transform: translateY(-5rpx) scale(1.035); box-shadow: 0 12rpx 24rpx rgba(244,92,136,.18); }
  100% { transform: translateY(0) scale(1); box-shadow: 0 8rpx 20rpx rgba(244,92,136,.12); }
}
@keyframes countLift {
  0% { transform: translateY(0); opacity: 1; }
  45% { transform: translateY(-3rpx); opacity: .88; }
  100% { transform: translateY(0); opacity: 1; }
}
