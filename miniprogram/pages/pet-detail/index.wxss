page { min-height: 100vh; background: #fff7f2; }
.page { position: relative; min-height: 100vh; overflow: hidden; }
.theme-bg { position: fixed; left: 0; top: 0; width: 100%; height: 100%; }
.theme-shade { position: fixed; left: 0; top: 0; width: 100%; height: 100%; background: linear-gradient(180deg, rgba(43,28,54,.08) 0%, rgba(43,28,54,.18) 32%, rgba(255,247,242,.42) 68%, rgba(255,247,242,.64) 100%); }
.topbar { position: absolute; left: 0; right: 0; z-index: 10; display: flex; align-items: center; justify-content: flex-end; gap: 16rpx; padding: 34rpx 30rpx; color: #fff; box-sizing: border-box; }
.topbar-actions { display: flex; align-items: center; gap: 12rpx; min-width: 0; }
.topbar-actions { justify-content: flex-end; }
.topbar button.share-button { width: 46rpx; min-width: 0; height: 46rpx; margin: 0; padding: 0; display: flex; align-items: center; justify-content: center; border-radius: 50%; background: rgba(255,255,255,.2); }
.topbar button.share-button::after { border: 0; }
.share { width: 34rpx; height: 34rpx; filter: brightness(0) invert(1); }
.topbar button.edit-button { width: auto; min-width: 0; height: 52rpx; margin: 0; padding: 0 12rpx; display: inline-flex; align-items: center; justify-content: center; gap: 6rpx; border-radius: 999rpx; background: rgba(255,255,255,.28); box-shadow: 0 10rpx 24rpx rgba(45,33,64,.16); backdrop-filter: blur(10rpx); flex: 0 0 auto; }
.topbar button.edit-button::after { border: 0; }
.edit-button image { width: 28rpx; height: 28rpx; filter: brightness(0) invert(1); }
.edit-label { color: #fff; font-size: 20rpx; font-weight: 900; line-height: 1; }
.hero { position: relative; z-index: 1; padding: 44rpx 40rpx 28rpx; color: #fff; text-shadow: 0 5rpx 16rpx rgba(45,33,64,.32); }
.hero-top { display: flex; align-items: flex-start; gap: 24rpx; }
.hero-copy { min-width: 0; flex: 1; display: flex; flex-direction: column; align-items: flex-start; }
.pet-photo { width: 136rpx; height: 136rpx; flex: 0 0 136rpx; border: 8rpx solid rgba(255,255,255,.82); border-radius: 50%; background: #fff; box-shadow: 0 18rpx 38rpx rgba(45,33,64,.26); }
.hero-main { display: flex; align-items: center; gap: 16rpx; flex-wrap: wrap; }
.name { font-size: 58rpx; font-weight: 900; }
.status-badge { padding: 10rpx 18rpx; border-radius: 999rpx; background: rgba(255,255,255,.22); font-size: 22rpx; font-weight: 900; backdrop-filter: blur(10rpx); }
.date { margin-top: 12rpx; font-size: 25rpx; font-weight: 700; }
.pill { align-self: flex-start; margin-top: 18rpx; padding: 12rpx 20rpx; border-radius: 999rpx; background: rgba(255,120,152,.92); font-size: 24rpx; font-weight: 900; box-shadow: 0 10rpx 24rpx rgba(45,33,64,.16); }
.hero-identity { width: 100%; min-width: 0; margin-top: 22rpx; padding: 16rpx 18rpx; display: flex; align-items: center; justify-content: space-between; gap: 16rpx; border-radius: 22rpx; background: rgba(255,248,236,.22); border: 2rpx solid rgba(255,255,255,.28); box-shadow: 0 12rpx 30rpx rgba(45,33,64,.12); backdrop-filter: blur(12rpx); box-sizing: border-box; }
.hero-identity-claim { align-items: stretch; gap: 18rpx; }
.hero-identity-copy { min-width: 0; display: flex; flex-direction: column; gap: 6rpx; }
.hero-identity-label { color: rgba(255,243,222,.88); font-size: 20rpx; font-weight: 800; }
.hero-identity-no { color: #fffdf7; font-size: 28rpx; font-weight: 900; letter-spacing: 1.5rpx; text-shadow: none; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.hero-identity-desc { color: #fffdf7; font-size: 21rpx; font-weight: 700; line-height: 1.45; text-shadow: none; }
.hero-identity-arrow { width: 26rpx; height: 26rpx; flex-shrink: 0; filter: brightness(0) invert(1); opacity: .86; }
.hero-identity-button { flex: 0 0 auto; align-self: center; min-width: 0; height: 72rpx; padding: 0 26rpx; border-radius: 999rpx; color: #7f5d16; background: rgba(255,244,224,.96); font-size: 22rpx; font-weight: 900; box-shadow: 0 10rpx 24rpx rgba(45,33,64,.12); white-space: nowrap; }
.hero-identity-button::after { border: 0; }
.sheet { position: relative; z-index: 2; margin: 24rpx; padding: 22rpx 24rpx 30rpx; border: 2rpx solid rgba(255,255,255,.42); border-radius: 28rpx; background: rgba(255,255,255,.46); box-shadow: 0 -10rpx 34rpx rgba(65,45,88,.11); backdrop-filter: blur(18rpx); }
.visitor-tip { display: flex; align-items: center; justify-content: space-between; gap: 16rpx; margin-bottom: 22rpx; padding: 18rpx 20rpx; border-radius: 20rpx; color: #6f6090; background: rgba(255,255,255,.78); font-size: 22rpx; font-weight: 800; line-height: 1.4; }
.visitor-back { flex-shrink: 0; color: #7a53e8; font-weight: 900; }
.feature-card,
.section-card { margin-top: 22rpx; padding: 20rpx 0 0; border-top: 2rpx solid rgba(125,112,143,.12); border-radius: 0; background: transparent; box-shadow: none; }
.feature-card { margin-top: 0; padding: 24rpx; background: linear-gradient(135deg, rgba(255,255,255,.92), rgba(255,241,233,.88)); box-shadow: 0 18rpx 40rpx rgba(145,88,71,.12); }
.interaction-card.first-card { margin-top: 0; padding-top: 0; border-top: 0; }
.feature-copy { display: flex; align-items: center; gap: 18rpx; }
.feature-icon { width: 88rpx; height: 88rpx; flex-shrink: 0; display: flex; align-items: center; justify-content: center; border-radius: 26rpx; background: linear-gradient(135deg, #ffb193, #ff866c); box-shadow: 0 12rpx 26rpx rgba(255,134,108,.24); }
.feature-icon image { width: 46rpx; height: 46rpx; filter: brightness(0) invert(1); }
.feature-text { min-width: 0; display: flex; flex-direction: column; gap: 8rpx; }
.feature-title { color: #2f2940; font-size: 31rpx; font-weight: 900; }
.feature-desc { color: #7a6471; font-size: 23rpx; font-weight: 700; line-height: 1.5; }
.feature-button { margin-top: 20rpx; height: 86rpx; display: flex; align-items: center; justify-content: center; border-radius: 999rpx; color: #fff; background: linear-gradient(135deg, #f78b6f, #eb6556); font-size: 27rpx; font-weight: 900; box-shadow: 0 16rpx 32rpx rgba(235,101,86,.24); }
.section-head { display: flex; align-items: baseline; justify-content: space-between; gap: 16rpx; margin-bottom: 20rpx; }
.section-head.compact { margin-bottom: 16rpx; }
.section-title { color: #2f2940; font-size: 28rpx; font-weight: 900; }
.section-tip { color: #9a7791; font-size: 20rpx; font-weight: 800; }
.overview-visitor { display: block; margin: 0 0 14rpx; padding: 0 0 14rpx; border-bottom: 2rpx solid rgba(154,119,145,.14); color: #8b7b9c; font-size: 21rpx; font-weight: 800; line-height: 1.5; }
.overview-note { display: block; margin: -2rpx 0 18rpx; color: #aa9687; font-size: 21rpx; font-weight: 700; line-height: 1.45; }
.actions { display: grid; grid-template-columns: repeat(3,1fr); gap: 10rpx; }
.action { min-width: 0; display: flex; flex-direction: row; align-items: center; gap: 10rpx; padding: 10rpx 6rpx; border-radius: 8rpx; color: #5e526f; font-size: 22rpx; font-weight: 800; background: transparent; }
.interaction-card.syncing .action { opacity: .46; }
.interaction-card.syncing .action.active-sync { opacity: 1; }
.action-icon { width: 62rpx; height: 62rpx; display: flex; align-items: center; justify-content: center; border-radius: 50%; background: rgba(255,255,255,.52); box-shadow: none; }
.action-icon image { width: 36rpx; height: 36rpx; }
.action-copy { min-width: 0; display: flex; flex-direction: column; align-items: flex-start; gap: 4rpx; }
.action-label { color: #5e526f; font-size: 22rpx; font-weight: 800; line-height: 1.1; white-space: nowrap; }
.action-count { color: #8e7ba6; font-size: 22rpx; font-weight: 900; line-height: 1; }
.stats { display: grid; gap: 12rpx; }
.stats-four { grid-template-columns: repeat(4,1fr); }
.stats-three { grid-template-columns: repeat(3,1fr); }
.stats-mixed { grid-template-columns: repeat(3,1fr); }
.stats-scroll { width: 100%; white-space: nowrap; }
.stats-inline { display: inline-flex; align-items: stretch; gap: 0; min-width: 100%; }
.stat { display: flex; flex-direction: column; align-items: flex-start; justify-content: center; min-height: 106rpx; padding: 18rpx 18rpx 18rpx 20rpx; border-radius: 18rpx; background: rgba(255,255,255,.46); box-sizing: border-box; }
.stat-inline { position: relative; flex: 1 0 0; min-width: 120rpx; min-height: 88rpx; padding: 6rpx 18rpx 8rpx 0; border-radius: 0; background: transparent; }
.stat-inline .stat-value { font-size: 34rpx; letter-spacing: -.5rpx; }
.stat-inline .stat-label { margin-top: 12rpx; font-size: 19rpx; letter-spacing: 1rpx; }
.stat-value { color: #2f2940; font-size: 34rpx; line-height: 1; }
.stat-label { margin-top: 10rpx; color: #9a7791; font-size: 20rpx; font-weight: 800; line-height: 1; }
.identity-card,
.identity-claim-card { margin-top: 22rpx; padding: 24rpx; border-radius: 24rpx; background: linear-gradient(135deg, rgba(255,251,238,.92), rgba(255,245,228,.8)); box-shadow: inset 0 0 0 2rpx rgba(255,255,255,.42), 0 16rpx 34rpx rgba(164,120,48,.12); }
.identity-head { display: flex; align-items: center; justify-content: space-between; gap: 16rpx; }
.identity-main { display: flex; flex-direction: column; gap: 8rpx; }
.identity-label { color: #9f7b2c; font-size: 22rpx; font-weight: 800; }
.identity-no { color: #2f2940; font-size: 36rpx; font-weight: 900; letter-spacing: 2rpx; }
.identity-arrow { width: 28rpx; height: 28rpx; flex-shrink: 0; opacity: .66; }
.identity-meta { display: grid; grid-template-columns: repeat(3,1fr); gap: 12rpx; margin-top: 20rpx; }
.identity-meta view { min-width: 0; padding: 14rpx 12rpx; display: flex; flex-direction: column; gap: 6rpx; border-radius: 8rpx; background: rgba(255,255,255,.62); box-sizing: border-box; }
.identity-meta text:first-child { color: #9f7b2c; font-size: 20rpx; font-weight: 800; }
.identity-meta text:last-child { color: #5e526f; font-size: 22rpx; font-weight: 900; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.identity-claim-copy { display: flex; flex-direction: column; gap: 10rpx; }
.identity-claim-title { color: #7f5d16; font-size: 30rpx; font-weight: 900; }
.identity-claim-desc { color: #8b7550; font-size: 23rpx; font-weight: 700; line-height: 1.5; }
.identity-claim-button { margin-top: 22rpx; height: 84rpx; border-radius: 42rpx; color: #fff; background: linear-gradient(135deg, #f0a743, #db7d2b); font-size: 27rpx; font-weight: 900; box-shadow: 0 14rpx 30rpx rgba(219,125,43,.22); }
.identity-claim-button::after { border: 0; }
.story-card { margin-top: 20rpx; padding: 20rpx 0 0; border-top: 2rpx solid rgba(125,112,143,.12); border-radius: 0; background: transparent; box-shadow: none; }
.story-head { display: flex; align-items: center; justify-content: space-between; gap: 16rpx; color: #e87553; font-size: 25rpx; font-weight: 900; }
.story-actions { display: flex; align-items: center; gap: 16rpx; flex-shrink: 0; }
.record-button { display: inline-flex; align-items: center; justify-content: center; min-width: 0; height: 52rpx; padding: 0 18rpx; border-radius: 999rpx; color: #fff; background: #f06f5b; font-size: 21rpx; font-weight: 900; line-height: 1; white-space: nowrap; }
.edit { color: #b98b73; }
.story { display: block; margin-top: 14rpx; color: #5e526f; font-size: 24rpx; line-height: 1.55; font-weight: 700; }
.story-empty-action { margin-top: 18rpx; height: 72rpx; display: inline-flex; align-items: center; justify-content: center; padding: 0 28rpx; border-radius: 999rpx; color: #f06f5b; background: rgba(240,111,91,.12); font-size: 23rpx; font-weight: 900; }
.recent-list { margin-top: 12rpx; display: flex; flex-direction: column; gap: 0; }
.recent-item { display: flex; align-items: center; justify-content: space-between; gap: 14rpx; padding: 14rpx 0; border-radius: 0; border-top: 2rpx solid rgba(125,112,143,.08); background: transparent; }
.recent-item:first-child { border-top: 0; }
.recent-copy { min-width: 0; display: flex; flex-direction: column; gap: 6rpx; }
.recent-title { color: #2f2940; font-size: 25rpx; font-weight: 900; }
.recent-desc { color: #5e526f; font-size: 22rpx; line-height: 1.35; font-weight: 700; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.recent-date { color: #9a7791; font-size: 20rpx; font-weight: 800; }
.recent-img { flex-shrink: 0; width: 104rpx; height: 78rpx; border-radius: 14rpx; }
.entry-section { margin-top: 20rpx; padding: 18rpx 0 0; }
.entry-section .section-head.compact { margin-bottom: 10rpx; }
.entry-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 18rpx; }
.entry { min-height: 72rpx; display: flex; flex-direction: row; align-items: center; justify-content: flex-start; gap: 12rpx; padding: 8rpx 0; border-radius: 0; color: #6d4fd1; background: transparent; font-size: 24rpx; font-weight: 900; box-sizing: border-box; }
.entry image { width: 38rpx; height: 38rpx; flex-shrink: 0; }
.entry-label { flex-shrink: 0; line-height: 1; }
.entry-count { margin-left: auto; color: #8e7ba6; font-size: 20rpx; font-weight: 800; line-height: 1; white-space: nowrap; }
.support-panel { margin-top: 22rpx; padding: 18rpx 20rpx; border-radius: 8rpx; background: rgba(255,255,255,.64); border: 2rpx solid rgba(125,112,143,.12); box-shadow: none; }
.support-panel.review-panel { display: flex; align-items: center; justify-content: space-between; gap: 16rpx; background: rgba(255,248,236,.72); border-color: rgba(196,143,47,.28); }
.support-copy { display: flex; flex-direction: column; gap: 8rpx; }
.review-panel .support-copy { flex: 1; min-width: 0; }
.support-title-row { display: flex; align-items: center; gap: 10rpx; }
.support-status-dot { width: 14rpx; height: 14rpx; border-radius: 50%; background: #d28a1f; flex-shrink: 0; }
.review-panel.status-approved { background: rgba(237,250,244,.78); border-color: rgba(41,114,93,.24); }
.review-panel.status-approved .support-status-dot { background: #2f9b79; }
.review-panel.status-pending .support-status-dot { background: #d28a1f; }
.review-panel.status-rejected .support-status-dot,
.review-panel.status-hidden .support-status-dot { background: #c94f60; }
.support-title { color: #2f2940; font-size: 24rpx; font-weight: 900; }
.support-desc { color: #7d708f; font-size: 21rpx; font-weight: 800; line-height: 1.45; }
.support-copy.status-approved .support-title, .support-copy.status-approved .support-desc { color: #29725d; }
.support-copy.status-pending .support-title, .support-copy.status-pending .support-desc { color: #7c5c14; }
.support-copy.status-rejected .support-title, .support-copy.status-rejected .support-desc, .support-copy.status-hidden .support-title, .support-copy.status-hidden .support-desc { color: #b34353; }
.support-actions { display: flex; flex-wrap: wrap; gap: 12rpx; margin-top: 18rpx; }
.review-panel .support-actions { flex-shrink: 0; margin-top: 0; }
.support-button { flex: 1 1 0; min-width: 0; height: 64rpx; padding: 0 16rpx; display: flex; align-items: center; justify-content: center; border-radius: 8rpx; color: #7a53e8; background: rgba(139,92,246,.1); font-size: 23rpx; font-weight: 900; line-height: 1.2; text-align: center; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; box-sizing: border-box; }
.support-button.wide { flex-basis: 100%; }
.review-panel .support-button.wide { flex-basis: auto; width: auto; height: 56rpx; padding: 0 18rpx; }
.support-button.primary { color: #fff; background: #8b5cf6; }
.support-button.plain { color: #6f6090; background: rgba(255,255,255,.82); }
.support-button.danger { color: #c94f60; background: rgba(255,224,230,.86); }
.login-empty { display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 100vh; padding: 80rpx 48rpx; background: linear-gradient(180deg,#dfcaff,#fff7fb); box-sizing: border-box; text-align: center; }
.empty-pet { width: 176rpx; height: 176rpx; border: 8rpx solid rgba(255,255,255,.86); border-radius: 50%; background: #fff; box-shadow: 0 16rpx 34rpx rgba(126,86,194,.16); }
.empty-title { margin-top: 28rpx; color: #2f2940; font-size: 34rpx; font-weight: 900; }
.empty-desc { margin-top: 12rpx; color: #786994; font-size: 25rpx; font-weight: 800; }
.login-empty .login-button { width: 320rpx; height: 78rpx; margin-top: 34rpx; border-radius: 39rpx; color: #fff; background: #8b5cf6; font-size: 28rpx; font-weight: 900; box-shadow: 0 14rpx 28rpx rgba(139,92,246,.24); }
.pet-skeleton { position: relative; min-height: 100vh; overflow: hidden; background: #fff7f2; }
.skeleton-bg { position: fixed; left: 0; top: 0; width: 100%; height: 100%; background: linear-gradient(180deg, #d9c3ff 0%, #f8d9e2 54%, #fff7f2 100%); }
.skeleton-hero { position: relative; z-index: 1; padding: 40rpx; display: flex; flex-direction: column; align-items: flex-start; }
.skeleton-sheet { position: relative; z-index: 2; margin: 24rpx; padding: 26rpx 22rpx 32rpx; border: 2rpx solid rgba(255,255,255,.5); border-radius: 32rpx; background: rgba(255,255,255,.58); box-shadow: 0 -12rpx 44rpx rgba(65,45,88,.14); }
.skeleton-actions { display: grid; grid-template-columns: repeat(3,1fr); gap: 16rpx; }
.skeleton-action { display: flex; flex-direction: column; align-items: center; gap: 10rpx; }
.skeleton-stats { display: grid; grid-template-columns: repeat(4,1fr); gap: 12rpx; margin-top: 28rpx; }
.skeleton-card { margin-top: 24rpx; padding: 24rpx; border-radius: 24rpx; background: rgba(255,255,255,.76); display: flex; flex-direction: column; gap: 14rpx; }
.skeleton-photo,
.skeleton-line,
.skeleton-pill,
.skeleton-icon,
.skeleton-stat {
  position: relative;
  overflow: hidden;
  background: rgba(255,255,255,.66);
}
.skeleton-photo::after,
.skeleton-line::after,
.skeleton-pill::after,
.skeleton-icon::after,
.skeleton-stat::after {
  content: "";
  position: absolute;
  left: -80%;
  top: 0;
  width: 70%;
  height: 100%;
  background: linear-gradient(90deg, rgba(255,255,255,0), rgba(255,255,255,.58), rgba(255,255,255,0));
  animation: pet-skeleton-shimmer 1.35s ease-in-out infinite;
}
.skeleton-photo { width: 136rpx; height: 136rpx; margin-bottom: 22rpx; border-radius: 50%; }
.skeleton-line { width: 72%; height: 24rpx; border-radius: 999rpx; }
.skeleton-line.name { width: 260rpx; height: 56rpx; }
.skeleton-line.date { width: 220rpx; margin-top: 18rpx; }
.skeleton-line.short { width: 90rpx; }
.skeleton-line.medium { width: 52%; }
.skeleton-line.card-title { width: 210rpx; height: 28rpx; }
.skeleton-pill { width: 280rpx; height: 52rpx; margin-top: 18rpx; border-radius: 999rpx; }
.skeleton-icon { width: 82rpx; height: 82rpx; border-radius: 50%; }
.skeleton-stat { height: 92rpx; border-radius: 22rpx; }

@media (max-width: 360px) {
  .stats-four,
  .stats-three,
  .stats-mixed { grid-template-columns: repeat(2,1fr); }
  .identity-meta { grid-template-columns: repeat(2,1fr); }
}

@keyframes pet-skeleton-shimmer {
  0% { transform: translateX(0); }
  100% { transform: translateX(260%); }
}
