page { min-height: 100vh; background: #fff7f2; }
.page { position: relative; min-height: 100vh; overflow: hidden; }
.theme-bg { position: fixed; left: 0; top: 0; width: 100%; height: 100%; }
.theme-shade { position: fixed; left: 0; top: 0; width: 100%; height: 100%; background: linear-gradient(180deg, rgba(43,28,54,.08) 0%, rgba(43,28,54,.18) 32%, rgba(255,247,242,.42) 68%, rgba(255,247,242,.64) 100%); }
.topbar { position: absolute; right: 0; z-index: 10; display: flex; justify-content: flex-end; gap: 16rpx; padding: 34rpx 30rpx; color: #fff; }
.topbar button.share-button { width: 46rpx; min-width: 0; height: 46rpx; margin: 0; padding: 0; display: flex; align-items: center; justify-content: center; border-radius: 50%; background: rgba(255,255,255,.2); }
.topbar button.share-button::after { border: 0; }
.share { width: 34rpx; height: 34rpx; filter: brightness(0) invert(1); }
.topbar button.edit-button { width: 46rpx; min-width: 0; height: 46rpx; margin: 0; padding: 0; border-radius: 50%; background: rgba(255,255,255,.2); }
.topbar button.edit-button::after { border: 0; }
.edit-button image { width: 34rpx; height: 34rpx; filter: brightness(0) invert(1); }
.hero { position: relative; z-index: 1; display: flex; flex-direction: column; align-items: flex-start; padding: 40rpx; color: #fff; text-shadow: 0 5rpx 16rpx rgba(45,33,64,.32); }
.pet-photo { width: 136rpx; height: 136rpx; margin-bottom: 22rpx; border: 8rpx solid rgba(255,255,255,.82); border-radius: 50%; background: #fff; box-shadow: 0 18rpx 38rpx rgba(45,33,64,.26); }
.name { font-size: 58rpx; font-weight: 900; }
.date { margin-top: 12rpx; font-size: 25rpx; font-weight: 700; }
.pill { align-self: flex-start; margin-top: 18rpx; padding: 12rpx 20rpx; border-radius: 999rpx; background: rgba(255,120,152,.92); font-size: 24rpx; font-weight: 900; box-shadow: 0 10rpx 24rpx rgba(45,33,64,.16); }
.sheet { position: relative; z-index: 2; margin: 24rpx; padding: 26rpx 22rpx 32rpx; border: 2rpx solid rgba(255,255,255,.5); border-radius: 32rpx; background: rgba(255,255,255,.58); box-shadow: 0 -12rpx 44rpx rgba(65,45,88,.14); }
.visitor-tip { display: flex; align-items: center; justify-content: space-between; gap: 16rpx; margin-bottom: 22rpx; padding: 18rpx 20rpx; border-radius: 20rpx; color: #6f6090; background: rgba(255,255,255,.78); font-size: 22rpx; font-weight: 800; line-height: 1.4; }
.visitor-back { flex-shrink: 0; color: #7a53e8; font-weight: 900; }
.actions { display: grid; grid-template-columns: repeat(3,1fr); gap: 16rpx; }
.action { display: flex; flex-direction: column; align-items: center; gap: 8rpx; color: #5e526f; font-size: 22rpx; font-weight: 800; }
.action-icon { width: 82rpx; height: 82rpx; display: flex; align-items: center; justify-content: center; border-radius: 50%; background: rgba(255,255,255,.86); box-shadow: 0 8rpx 22rpx rgba(126,84,230,.16); }
.action-icon image { width: 48rpx; height: 48rpx; }
.action-count { color: #8e7ba6; font-size: 19rpx; font-weight: 800; }
.stats { display: grid; grid-template-columns: repeat(4,1fr); gap: 12rpx; margin-top: 28rpx; }
.stat { display: flex; flex-direction: column; align-items: center; padding: 18rpx 0; border-radius: 22rpx; background: rgba(255,255,255,.72); }
.stat-value { color: #2f2940; font-size: 30rpx; font-weight: 900; }
.stat-label { margin-top: 6rpx; color: #9a7791; font-size: 21rpx; font-weight: 800; }
.visitor-summary { display: flex; align-items: center; justify-content: space-between; gap: 14rpx; margin-top: 18rpx; padding: 18rpx 20rpx; border-radius: 20rpx; color: #6f6090; background: rgba(255,255,255,.7); font-size: 22rpx; font-weight: 900; }
.story-card { margin-top: 24rpx; padding: 24rpx; border-radius: 24rpx; background: rgba(255,255,255,.76); }
.story-head { display: flex; justify-content: space-between; color: #e87553; font-size: 25rpx; font-weight: 900; }
.edit { color: #b98b73; }
.story { display: block; margin-top: 14rpx; color: #5e526f; font-size: 24rpx; line-height: 1.55; font-weight: 700; }
.recent-list { margin-top: 14rpx; display: flex; flex-direction: column; gap: 12rpx; }
.recent-item { display: flex; align-items: center; justify-content: space-between; gap: 14rpx; padding: 14rpx; border-radius: 18rpx; background: rgba(255,255,255,.62); }
.recent-copy { min-width: 0; display: flex; flex-direction: column; gap: 6rpx; }
.recent-title { color: #2f2940; font-size: 25rpx; font-weight: 900; }
.recent-desc { color: #5e526f; font-size: 22rpx; line-height: 1.35; font-weight: 700; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.recent-date { color: #9a7791; font-size: 20rpx; font-weight: 800; }
.recent-img { flex-shrink: 0; width: 104rpx; height: 78rpx; border-radius: 14rpx; }
.entry-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 14rpx; margin-top: 22rpx; }
.entry { display: flex; flex-direction: column; align-items: center; gap: 8rpx; padding: 20rpx 0; border-radius: 22rpx; color: #7a53e8; background: rgba(255,255,255,.76); font-size: 22rpx; font-weight: 900; }
.entry image { width: 44rpx; height: 44rpx; }
.login-empty { display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 100vh; padding: 80rpx 48rpx; background: linear-gradient(180deg,#dfcaff,#fff7fb); box-sizing: border-box; text-align: center; }
.empty-pet { width: 176rpx; height: 176rpx; border: 8rpx solid rgba(255,255,255,.86); border-radius: 50%; background: #fff; box-shadow: 0 16rpx 34rpx rgba(126,86,194,.16); }
.empty-title { margin-top: 28rpx; color: #2f2940; font-size: 34rpx; font-weight: 900; }
.empty-desc { margin-top: 12rpx; color: #786994; font-size: 25rpx; font-weight: 800; }
.login-empty .login-button { width: 320rpx; height: 78rpx; margin-top: 34rpx; border-radius: 39rpx; color: #fff; background: #8b5cf6; font-size: 28rpx; font-weight: 900; box-shadow: 0 14rpx 28rpx rgba(139,92,246,.24); }
