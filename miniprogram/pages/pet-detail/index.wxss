page { min-height: 100vh; background: #fff7f2; }
.page { position: relative; min-height: 100vh; overflow: hidden; }
.cover { position: absolute; left: 0; top: 0; width: 100%; height: 560rpx; }
.shade { position: absolute; left: 0; top: 0; width: 100%; height: 620rpx; background: linear-gradient(180deg, rgba(38,24,35,.12), rgba(255,247,242,.95)); }
.topbar { position: relative; z-index: 1; display: flex; justify-content: space-between; padding: 34rpx 30rpx; color: #fff; }
.back { font-size: 58rpx; line-height: 1; }
.share { width: 46rpx; height: 46rpx; filter: brightness(0) invert(1); }
.hero { position: relative; z-index: 1; display: flex; flex-direction: column; padding: 210rpx 40rpx 0; color: #fff; text-shadow: 0 5rpx 16rpx rgba(45,33,64,.32); }
.name { font-size: 58rpx; font-weight: 900; }
.date { margin-top: 12rpx; font-size: 25rpx; font-weight: 700; }
.pill { align-self: flex-start; margin-top: 18rpx; padding: 12rpx 20rpx; border-radius: 999rpx; background: #ff7898; font-size: 24rpx; font-weight: 900; }
.sheet { position: relative; z-index: 2; margin: 50rpx 24rpx 0; padding-bottom: 32rpx; }
.actions { display: grid; grid-template-columns: repeat(4,1fr); gap: 16rpx; }
.action { display: flex; flex-direction: column; align-items: center; gap: 10rpx; color: #5e526f; font-size: 22rpx; font-weight: 800; }
.action-icon { width: 82rpx; height: 82rpx; display: flex; align-items: center; justify-content: center; border-radius: 50%; background: rgba(255,255,255,.84); box-shadow: 0 8rpx 22rpx rgba(126,84,230,.16); }
.action-icon image { width: 48rpx; height: 48rpx; }
.stats { display: grid; grid-template-columns: repeat(4,1fr); gap: 12rpx; margin-top: 28rpx; }
.stat { display: flex; flex-direction: column; align-items: center; padding: 18rpx 0; border-radius: 22rpx; background: rgba(255,255,255,.78); }
.stat-value { color: #2f2940; font-size: 30rpx; font-weight: 900; }
.stat-label { margin-top: 6rpx; color: #9a7791; font-size: 21rpx; font-weight: 800; }
.story-card { margin-top: 24rpx; padding: 24rpx; border-radius: 24rpx; background: rgba(255,255,255,.82); }
.story-head { display: flex; justify-content: space-between; color: #e87553; font-size: 25rpx; font-weight: 900; }
.edit { color: #b98b73; }
.story { display: block; margin-top: 14rpx; color: #5e526f; font-size: 24rpx; line-height: 1.55; font-weight: 700; }
.entry-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 14rpx; margin-top: 22rpx; }
.entry { display: flex; flex-direction: column; align-items: center; gap: 8rpx; padding: 20rpx 0; border-radius: 22rpx; color: #7a53e8; background: rgba(255,255,255,.82); font-size: 22rpx; font-weight: 900; }
.entry image { width: 44rpx; height: 44rpx; }
