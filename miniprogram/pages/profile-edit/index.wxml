<view class="page">
  <image-uploader
    id="avatarUploader"
    value="{{form.avatarUrl}}"
    image-type="avatar"
    crop-ratio="1:1"
    bindchange="onAvatarChange"
  />

  <view class="form-panel">
    <text class="label">昵称</text>
    <input
      class="nickname-input"
      type="nickname"
      placeholder="选择微信昵称或自己输入"
      value="{{form.nickname}}"
      bindinput="onNicknameInput"
    />
  </view>

  <button class="save-button" disabled="{{saving}}" bindtap="saveProfile">
    <text>{{saving ? '保存中...' : '保存资料'}}</text>
  </button>

  <view wx:if="{{saving}}" class="submit-mask" catchtouchmove="noop">
    <view class="submit-dialog">
      <view class="submit-spinner"></view>
      <text class="submit-title">正在保存</text>
      <text class="submit-desc">请稍候，正在处理头像和资料</text>
    </view>
  </view>
</view>
