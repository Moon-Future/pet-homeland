page { min-height: 100vh; background: #f6f0ff; }
.page { min-height: 100vh; padding: 44rpx 28rpx 88rpx; background: linear-gradient(180deg,#f0e4ff,#fff8fb); box-sizing: border-box; }
.avatar-section { display: flex; flex-direction: column; align-items: center; padding: 42rpx 24rpx; border-radius: 24rpx; background: rgba(255,255,255,.78); box-shadow: 0 18rpx 38rpx rgba(126,86,194,.12); }
.avatar-wrap { position: relative; width: 164rpx; height: 164rpx; }
.avatar-wrap .avatar-button { width: 164rpx; height: 164rpx; border-radius: 50%; overflow: hidden; }
.avatar { width: 164rpx; height: 164rpx; border: 8rpx solid rgba(255,255,255,.9); border-radius: 50%; box-sizing: border-box; background: #fff; box-shadow: 0 16rpx 32rpx rgba(126,86,194,.18); }
.avatar-wrap .camera-button { position: absolute; bottom: 0rpx; width: 30rpx; height: 30rpx; border-radius: 50%; background: #8b5cf6; box-shadow: 0 10rpx 20rpx rgba(139,92,246,.26); }
.camera-icon { width: 30rpx; height: 30rpx; }
.avatar-tip { margin-top: 18rpx; color: #786994; font-size: 23rpx; font-weight: 800; }
.form-panel { margin-top: 24rpx; padding: 26rpx 24rpx; border-radius: 24rpx; background: rgba(255,255,255,.78); box-shadow: 0 18rpx 38rpx rgba(126,86,194,.1); }
.label { display: block; color: #6f6090; font-size: 23rpx; font-weight: 900; }
.nickname-input { height: 72rpx; margin-top: 10rpx; color: #2f2940; font-size: 32rpx; font-weight: 900; line-height: 72rpx; }
.page .save-button { width: 100%; height: 84rpx; margin-top: 34rpx; border-radius: 42rpx; color: #fff; background: #8b5cf6; font-size: 29rpx; font-weight: 900; box-shadow: 0 16rpx 32rpx rgba(139,92,246,.26); }
.page .save-button[disabled] { opacity: .62; }
