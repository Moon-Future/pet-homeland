page { min-height: 100vh; background: #f6f0ff; }
.page { min-height: 100vh; padding: 44rpx 28rpx 88rpx; background: linear-gradient(180deg,#f0e4ff,#fff8fb); box-sizing: border-box; }
.form-panel { margin-top: 24rpx; padding: 26rpx 24rpx; border-radius: 24rpx; background: rgba(255,255,255,.78); box-shadow: 0 18rpx 38rpx rgba(126,86,194,.1); }
.label { display: block; color: #6f6090; font-size: 23rpx; font-weight: 900; }
.nickname-input { height: 72rpx; margin-top: 10rpx; color: #2f2940; font-size: 32rpx; font-weight: 900; line-height: 72rpx; }
.page .save-button { width: 100%; height: 84rpx; margin-top: 34rpx; border-radius: 42rpx; color: #fff; background: #8b5cf6; font-size: 29rpx; font-weight: 900; box-shadow: 0 16rpx 32rpx rgba(139,92,246,.26); }
.page .save-button[disabled] { opacity: .62; }
.submit-mask { position: fixed; left: 0; right: 0; top: 0; bottom: 0; z-index: 9999; display: flex; align-items: center; justify-content: center; background: rgba(47,41,64,.36); backdrop-filter: blur(8rpx); }
.submit-dialog { width: 320rpx; min-height: 230rpx; padding: 34rpx 28rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; border-radius: 8rpx; background: rgba(255,255,255,.96); box-shadow: 0 18rpx 44rpx rgba(47,41,64,.18); box-sizing: border-box; }
.submit-spinner { width: 58rpx; height: 58rpx; border: 6rpx solid rgba(139,92,246,.16); border-top-color: #8b5cf6; border-radius: 50%; animation: submit-spin .8s linear infinite; }
.submit-title { margin-top: 22rpx; color: #2f2940; font-size: 28rpx; font-weight: 900; }
.submit-desc { margin-top: 8rpx; color: #8e7ba6; font-size: 22rpx; font-weight: 800; }
@keyframes submit-spin { to { transform: rotate(360deg); } }
