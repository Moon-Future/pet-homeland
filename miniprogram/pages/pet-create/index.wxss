page {
  min-height: 100vh;
  background: #f7f0ff;
}

.page {
  min-height: 100vh;
  padding: 30rpx 26rpx;
  background:
    radial-gradient(circle at 18% 18%, rgba(255, 255, 255, 0.9) 0 2rpx, transparent 3rpx),
    radial-gradient(circle at 82% 20%, rgba(255, 230, 140, 0.9) 0 3rpx, transparent 4rpx),
    linear-gradient(180deg, #f3eaff 0%, #fff7fb 62%, #fff9f2 100%);
  box-sizing: border-box;
}

.panel {
  position: relative;
  min-height: calc(100vh - 60rpx);
  overflow: hidden;
  padding: 44rpx 34rpx 40rpx;
  display: flex;
  flex-direction: column;
  border-radius: 22rpx;
  background:
    radial-gradient(circle at 16% 66%, rgba(183, 139, 255, 0.18) 0 8rpx, transparent 9rpx),
    radial-gradient(circle at 86% 50%, rgba(255, 255, 255, 0.9) 0 5rpx, transparent 6rpx),
    linear-gradient(180deg, rgba(247, 238, 255, 0.96), rgba(255, 250, 255, 0.94));
  box-sizing: border-box;
}

.title-group {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.title {
  color: #2f2940;
  font-size: 34rpx;
  font-weight: 900;
}

.subtitle {
  margin-top: 12rpx;
  color: #74668f;
  font-size: 24rpx;
  font-weight: 700;
}

.stepper {
  position: relative;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  margin-top: 42rpx;
}

.stepper::before {
  position: absolute;
  left: 15%;
  right: 15%;
  top: 20rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: #ded3ee;
  content: "";
}

.step-item {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  color: #9a90aa;
  font-size: 22rpx;
  font-weight: 800;
}

.step-item.active {
  color: #8b5cf6;
}

.step-dot {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  color: #ffffff;
  background: #c7bfce;
  font-size: 22rpx;
  font-weight: 900;
}

.step-item.active .step-dot {
  background: linear-gradient(135deg, #b46dff, #8b5cf6);
  box-shadow: 0 8rpx 18rpx rgba(139, 92, 246, 0.26);
}

.upload-step {
  position: relative;
  flex: 1;
  min-height: 560rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 54rpx 0 34rpx;
}

.paw {
  position: absolute;
  width: 72rpx;
  height: 72rpx;
  opacity: 0.36;
  pointer-events: none;
}

.paw image {
  width: 100%;
  height: 100%;
}

.paw-left {
  left: 18rpx;
  top: 390rpx;
  transform: rotate(-18deg);
}

.paw-right {
  right: 20rpx;
  top: 250rpx;
  transform: rotate(18deg);
}

.form-step {
  flex: 1;
  padding-top: 42rpx;
}

.field {
  margin-bottom: 28rpx;
}

.field-label {
  display: block;
  margin-bottom: 14rpx;
  color: #2f2940;
  font-size: 26rpx;
  font-weight: 900;
}

.input,
.date-input,
.textarea {
  width: 100%;
  border: 2rpx solid rgba(139, 92, 246, 0.16);
  border-radius: 22rpx;
  color: #2f2940;
  background: rgba(255, 255, 255, 0.82);
  font-size: 28rpx;
  font-weight: 700;
  box-sizing: border-box;
}

.input,
.date-input {
  height: 88rpx;
  padding: 0 24rpx;
  line-height: 88rpx;
}

.textarea {
  height: 150rpx;
  padding: 22rpx 24rpx;
  line-height: 1.45;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.chip-row.compact {
  gap: 10rpx;
}

.chip {
  min-width: 112rpx;
  height: 64rpx;
  padding: 0 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(139, 92, 246, 0.14);
  border-radius: 999rpx;
  color: #5c526d;
  background: rgba(255, 255, 255, 0.74);
  font-size: 25rpx;
  font-weight: 900;
  box-sizing: border-box;
}

.chip.active {
  color: #ffffff;
  border-color: #9b68f2;
  background: linear-gradient(135deg, #b46dff, #8b5cf6);
  box-shadow: 0 10rpx 22rpx rgba(139, 92, 246, 0.2);
}

.status-options {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.visibility-options {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.visibility-option {
  min-height: 104rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 8rpx;
  padding: 20rpx 22rpx;
  border: 2rpx solid rgba(139, 92, 246, 0.14);
  border-radius: 22rpx;
  color: #5c526d;
  background: rgba(255, 255, 255, 0.72);
  font-size: 27rpx;
  font-weight: 900;
  box-sizing: border-box;
}

.visibility-option.active {
  color: #ffffff;
  border-color: rgba(255, 255, 255, 0.72);
  background: linear-gradient(135deg, #b46dff, #8b5cf6);
  box-shadow: 0 14rpx 30rpx rgba(139, 92, 246, 0.22);
}

.status-option {
  min-height: 130rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 10rpx;
  padding: 22rpx;
  border: 2rpx solid rgba(139, 92, 246, 0.14);
  border-radius: 24rpx;
  color: #5c526d;
  background: rgba(255, 255, 255, 0.72);
  font-size: 28rpx;
  font-weight: 900;
  box-sizing: border-box;
}

.status-option.active {
  color: #ffffff;
  border-color: rgba(255, 255, 255, 0.72);
  background: linear-gradient(135deg, #b46dff, #8b5cf6);
  box-shadow: 0 14rpx 30rpx rgba(139, 92, 246, 0.24);
}

.option-note {
  font-size: 21rpx;
  font-weight: 700;
  opacity: 0.78;
}

.theme-step {
  flex: 1;
  padding-top: 42rpx;
}

.theme-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 24rpx;
}

.theme-card {
  position: relative;
  height: 196rpx;
  overflow: hidden;
  border: 5rpx solid rgba(255, 255, 255, 0.72);
  border-radius: 24rpx;
  box-shadow: 0 14rpx 26rpx rgba(83, 70, 166, 0.16);
}

.theme-card.active {
  border-color: #b46dff;
  box-shadow: 0 16rpx 30rpx rgba(139, 92, 246, 0.28);
}

.theme-image {
  width: 100%;
  height: 100%;
}

.theme-name {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 54rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  background: linear-gradient(180deg, transparent, rgba(66, 48, 124, 0.5));
  font-size: 26rpx;
  font-weight: 900;
  text-shadow: 0 3rpx 8rpx rgba(45, 33, 64, 0.36);
}

.footer-actions {
  width: 100%;
  margin-top: 34rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 22rpx;
}

.footer-actions.single {
  grid-template-columns: 1fr;
}

.footer-actions button.prev-button,
.footer-actions button.next-button {
  width: 100%;
  min-width: 0;
  height: 84rpx;
  margin: 0;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1;
  box-sizing: border-box;
}

.footer-actions button.prev-button {
  border: 2rpx solid rgba(147, 104, 235, 0.32);
  color: #8b5cf6;
  background: rgba(255, 255, 255, 0.72);
}

.footer-actions button.next-button {
  color: #ffffff;
  background: linear-gradient(135deg, #b46dff, #8b5cf6);
  box-shadow: 0 14rpx 28rpx rgba(139, 92, 246, 0.28);
}

.footer-actions button.prev-button::after,
.footer-actions button.next-button::after {
  border: 0;
}

.submit-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(47, 41, 64, 0.36);
  backdrop-filter: blur(8rpx);
}

.submit-dialog {
  width: 320rpx;
  min-height: 230rpx;
  padding: 34rpx 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 18rpx 44rpx rgba(47, 41, 64, 0.18);
  box-sizing: border-box;
}

.submit-spinner {
  width: 58rpx;
  height: 58rpx;
  border: 6rpx solid rgba(139, 92, 246, 0.16);
  border-top-color: #8b5cf6;
  border-radius: 50%;
  animation: submit-spin 0.8s linear infinite;
}

.submit-title {
  margin-top: 22rpx;
  color: #2f2940;
  font-size: 28rpx;
  font-weight: 900;
}

.submit-desc {
  margin-top: 8rpx;
  color: #8e7ba6;
  font-size: 22rpx;
  font-weight: 800;
}

@keyframes submit-spin {
  to { transform: rotate(360deg); }
}
