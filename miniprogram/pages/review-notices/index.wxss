page { min-height: 100vh; background: #f7f4fb; }
.page { min-height: 100vh; padding: 32rpx 26rpx 80rpx; box-sizing: border-box; }
.header { display: flex; align-items: center; justify-content: space-between; }
.title { color: #2f2940; font-size: 38rpx; font-weight: 900; }
.refresh { width: 132rpx; height: 60rpx; margin: 0; padding: 0; border-radius: 30rpx; color: #fff; background: #8b5cf6; font-size: 24rpx; font-weight: 900; line-height: 60rpx; }
.refresh::after { border: 0; }
.list { display: flex; flex-direction: column; gap: 18rpx; margin-top: 28rpx; }
.notice { padding: 22rpx; border-radius: 8rpx; background: #fff; box-shadow: 0 12rpx 28rpx rgba(68,50,99,.08); }
.notice-head { display: flex; align-items: center; justify-content: space-between; gap: 18rpx; }
.notice-title { min-width: 0; color: #2f2940; font-size: 28rpx; font-weight: 900; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.status { flex: none; padding: 6rpx 14rpx; border-radius: 999rpx; color: #29725d; background: rgba(216,246,235,.9); font-size: 20rpx; font-weight: 900; }
.status.pending_review { color: #7c5c14; background: rgba(255,238,185,.9); }
.status.rejected, .status.hidden { color: #b34353; background: rgba(255,224,230,.9); }
.type { display: block; margin-top: 10rpx; color: #8e7ba6; font-size: 21rpx; font-weight: 900; }
.desc { display: block; margin-top: 10rpx; color: #5e526f; font-size: 24rpx; font-weight: 700; line-height: 1.45; }
.empty { display: flex; flex-direction: column; align-items: center; margin-top: 160rpx; color: #8e7ba6; font-size: 26rpx; font-weight: 900; }
.empty image { width: 168rpx; height: 168rpx; margin-bottom: 24rpx; border-radius: 50%; background: #fff; box-shadow: 0 14rpx 30rpx rgba(126,84,230,.12); }
